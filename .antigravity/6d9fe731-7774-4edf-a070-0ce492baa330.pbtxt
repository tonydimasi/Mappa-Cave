    instruction: "Update UndergroundMap with refs synchronization, MapLibre GL instance, smaller thematic markers, and the style guide palette"
    replacement_infos {
      original_chunk {
        target_content: "  categoryFilter,\n  searchQuery,\n  onSelectSite,\n}) => {\n  const mapContainerRef = useRef<HTMLDivElement>(null);\n  const deckInstanceRef = useRef<any>(null);\n  const viewStateRef = useRef<any>({\n    longitude: 14.250,\n    latitude: 40.848,\n    zoom: 14.3,\n    pitch: 55,\n    bearing: -5,\n  });\n\n  // Master layer renderer\n  const updateLayers = () => {\n    if (!deckInstanceRef.current) return;\n    const { ScatterplotLayer, TripsLayer, TextLayer } = (window as any).deck;\n    if (!ScatterplotLayer || !TripsLayer || !TextLayer) return;\n\n    const time = (Date.now() / 4) % 1000;\n\n    // Apply filters matching sidebar logic\n    const filtered = SITES_DATA.filter((s) => {\n      const matchesCat = categoryFilter === \'all\' || s.category === categoryFilter;\n      const matchesSearch =\n        s.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n        s.desc.toLowerCase().includes(searchQuery.toLowerCase());\n      return matchesCat && matchesSearch;\n    });\n\n    const layers = [\n      // 1. TripsLayer - Sub-surface water channels and Roman aqueduct pipes\n      new TripsLayer({\n        id: \'trips\',\n        data: TRIPS_DATA,\n        getPath: (d: any) => d.path,\n        getTimestamps: (d: any) => d.timestamps,\n        getColor: (d: any) => d.color,\n        opacity: 0.55,\n        widthMinPixels: 3,\n        trailLength: 450,\n        currentTime: time,\n      }),\n\n      // 2. Selected Site Aura Glow\n      ...(selectedSite\n        ? [\n            new ScatterplotLayer({\n              id: \'marker-selected-aura\',\n              data: [selectedSite],\n              getPosition: (d: any) => d.coords,\n              getRadius: 160,\n              radiusMinPixels: 25,\n              radiusMaxPixels: 60,\n              getFillColor: [201, 168, 76, 35], // Translucent gold aura\n              stroked: true,\n              lineWidthMinPixels: 1.5,\n              getLineColor: [201, 168, 76, 160],\n            }),\n          ]\n        : []),\n\n      // 3. Primary Archeological Markers\n      new ScatterplotLayer({\n        id: \'markers-primary\',\n        data: filtered,\n        getPosition: (d: any) => d.coords,\n        getFillColor: (d: any) => {\n          if (d.category === \'acqua\') return [74, 139, 201];       // Sky water\n          if (d.category === \'catacomba\') return [201, 74, 74];    // Cinnabar red\n          if (d.category === \'rifugio\') return [74, 201, 122];     // Emerald shelter\n          return [201, 168, 76];                                   // Gold ipogeo\n        },\n        getRadius: 40,\n        radiusMinPixels: 9,\n        radiusMaxPixels: 18,\n        pickable: true,\n        stroked: true,\n        lineWidthMinPixels: 2,\n        getLineColor: (d: any) => {\n          if (selectedSite && d.id === selectedSite.id) {\n            return [255, 255, 255, 255]; // Bold white border for current focused marker\n          }\n          return [10, 8, 6, 200]; // Deep ink boundary\n        },\n        onClick: (info: any) => {\n          if (info && info.object) {\n            onSelectSite(info.object);\n          }\n        },\n      }),\n\n      // 4. Site Identifier Labels (dimmed and styled dynamically)\n      new TextLayer({\n        id: \'map-labels\',\n        data: filtered,\n        getPosition: (d: any) => d.coords,\n        getText: (d: any) => d.name.split(\' (\')[0], // Elegant trim of long titles\n        getSize: 10.5,\n        getPixelOffset: [0, -26],\n        getColor: (d: any) => {\n          if (selectedSite && d.id === selectedSite.id) {\n            return [245, 237, 216, 255]; // Highlighted parchment string\n          }\n          return [158, 142, 122, 180]; // Stone ash dust\n        },\n        fontFamily: \'Playfair Display, serif\',\n        fontWeight: 600,\n        textAnchor: \'middle\',\n        alignmentBaseline: \'bottom\',\n      }),\n    ];\n\n    deckInstanceRef.current.setProps({ layers });\n  };\n\n  // Setup main DeckGL engine and coordinate boundaries\n  useEffect(() => {\n    if (!mapContainerRef.current) return;\n    const { DeckGL } = (window as any).deck;\n    if (!DeckGL) return;\n\n    const deckInstance = new DeckGL({\n      container: mapContainerRef.current,\n      mapStyle: \'https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json\',\n      initialViewState: viewStateRef.current,\n      controller: true,\n      onViewStateChange: ({ viewState: vs }: any) => {\n        viewStateRef.current = vs;\n        updateLayers();\n      },\n      getCursor: ({ isHovering }: any) => (isHovering ? \'pointer\' : \'grab\'),\n      getTooltip: ({ object }: any) =>\n        object && {\n          html: `\n            <div style=\"font-family:\'Playfair Display\', serif; border-bottom: 0.5px solid rgba(201,168,76,0.5); padding-bottom: 6px; margin-bottom: 6px;\">\n              <span style=\"color:#C9A84C; font-weight:700; font-size:15px\">${object.name}</span>\n            </div>\n            <div style=\"font-family:\'Inter\', sans-serif; font-size:11px; color:#9E8E7A; display:flex; justify-content:space-between; gap:20px\">\n              <span>Profondit\303\240: <strong style=\"color:#F5EDD8\">${object.depth}m</strong></span>\n              <span style=\"text-transform:uppercase; color:#C9A84C; font-weight:600\">${object.category}</span>\n            </div>\n          `,\n          className: \'deck-tooltip\',\n        },\n    });\n\n    deckInstanceRef.current = deckInstance;\n\n    // Animation frames loop for real-time aqueduct streams\n    let animationFrameId: number;\n    const renderLoop = () => {\n      updateLayers();\n      animationFrameId = requestAnimationFrame(renderLoop);\n    };\n    renderLoop();\n\n    return () => {\n      cancelAnimationFrame(animationFrameId);\n      if (deckInstanceRef.current) {\n        deckInstanceRef.current.finalize();\n      }\n    };\n  }, []);\n\n  // Update deck layers when categories or searches adapt\n  useEffect(() => {\n    if (deckInstanceRef.current) {\n      updateLayers();\n    }\n  }, [categoryFilter, searchQuery, selectedSite]);\n\n  // Command FlyTo flight camera with 60 degree pitch upon site focus\n  useEffect(() => {\n    if (selectedSite && deckInstanceRef.current) {\n      const { FlyToInterpolator } = (window as any).deck;\n      if (!FlyToInterpolator) return;\n\n      viewStateRef.current = {\n        ...viewStateRef.current,\n        longitude: selectedSite.coords[0],\n        latitude: selectedSite.coords[1],\n        zoom: 16.5,\n        pitch: 60,\n        bearing: -5,\n        transitionDuration: 2200,\n        transitionInterpolator: new FlyToInterpolator(),\n      };\n\n      deckInstanceRef.current.setProps({\n        viewState: viewStateRef.current,\n      });\n    }\n  }, [selectedSite]);\n\n  return (\n    <div className=\"w-full h-full relative\" style={{ backgroundColor: \'#050403\' }}>\n      {/* Underlying map frame element target */}\n      <div id=\"map-wrapper\" ref={mapContainerRef} className=\"w-full h-full\" />\n\n      {/* Floating Legend Panel representing zero-cyber parchment styles */}\n      <div className=\"absolute bottom-6 right-6 p-5 bg-ink/95 border border-gold-dim/40 rounded-none shadow-2xl flex flex-col gap-3.5 max-w-[280px] pointer-events-auto z-50\">\n        <h4 className=\"font-serif text-[13px] tracking-widest text-gold uppercase border-b border-stone-light/40 pb-2 font-bold select-none\">\n          Legenda Unicum\n        </h4>\n        <div className=\"flex flex-col gap-2.5 font-sans text-[11px] text-parchment/90\">\n          <div className=\"flex items-center gap-3\">\n            <span className=\"w-3.5 h-3.5 rounded-full bg-[#4A8BC9] border border-white/20 shadow-md flex-shrink-0\" />\n            <span className=\"font-medium\">Acquedotti e Cisterne</span>\n          </div>\n          <div className=\"flex items-center gap-3\">\n            <span className=\"w-3.5 h-3.5 rounded-full bg-[#C94A4A] border border-white/20 shadow-md flex-shrink-0\" />\n            <span className=\"font-medium\">Necropoli e Catacombe</span>\n          </div>\n          <div className=\"flex items-center gap-3\">\n            <span className=\"w-3.5 h-3.5 rounded-full bg-[#4AC97A] border border-white/20 shadow-md flex-shrink-0\" />\n            <span className=\"font-medium\">Rifugi Antiaerei WWII</span>\n          </div>\n          <div className=\"flex items-center gap-3\">\n            <span className=\"w-3.5 h-3.5 rounded-full bg-[#C9A84C] border border-white/20 shadow-md flex-shrink-0\" />\n            <span className=\"font-medium\">Ipogei Ellenistici Greci</span>\n          </div>\n          <div className=\"flex items-center gap-3 border-t border-stone-light/20 pt-2 opacity-80\">\n            <span className=\"w-6 h-0.5 bg-gold-light/60 flex-shrink-0 relative overflow-hidden\">\n              <span className=\"absolute inset-0 bg-sky-400 animate-pulse\" />\n            </span>\n            <span className=\"font-light text-[10px] text-dust-light\">Flussi Idrici Sotterranei</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n};"
        replacement_content: "  categoryFilter,\n  searchQuery,\n  onSelectSite,\n}) => {\n  const mapContainerRef = useRef<HTMLDivElement>(null);\n  const deckInstanceRef = useRef<any>(null);\n  const viewStateRef = useRef<any>({\n    longitude: 14.250,\n    latitude: 40.848,\n    zoom: 14.3,\n    pitch: 55,\n    bearing: -5,\n  });\n\n  // Create state references to bypass stale closures in the animation render loop\n  const categoryFilterRef = useRef(categoryFilter);\n  const searchQueryRef = useRef(searchQuery);\n  const selectedSiteRef = useRef(selectedSite);\n\n  // Keep references continuously synchronized\n  categoryFilterRef.current = categoryFilter;\n  searchQueryRef.current = searchQuery;\n  selectedSiteRef.current = selectedSite;\n\n  // Master layer renderer\n  const updateLayers = () => {\n    if (!deckInstanceRef.current) return;\n    const { ScatterplotLayer, TripsLayer, TextLayer } = (window as any).deck;\n    if (!ScatterplotLayer || !TripsLayer || !TextLayer) return;\n\n    const time = (Date.now() / 4) % 1000;\n\n    const activeFilter = categoryFilterRef.current;\n    const activeSearch = searchQueryRef.current;\n    const activeSelected = selectedSiteRef.current;\n\n    // Apply active filtration params\n    const filtered = SITES_DATA.filter((s) => {\n      const matchesCat = activeFilter === \'all\' || s.category === activeFilter;\n      const matchesSearch =\n        s.name.toLowerCase().includes(activeSearch.toLowerCase()) ||\n        s.desc.toLowerCase().includes(activeSearch.toLowerCase());\n      return matchesCat && matchesSearch;\n    });\n\n    const layers = [\n      // 1. TripsLayer - Sub-surface water channels\n      new TripsLayer({\n        id: \'trips\',\n        data: TRIPS_DATA,\n        getPath: (d: any) => d.path,\n        getTimestamps: (d: any) => d.timestamps,\n        getColor: () => [146, 64, 14, 180], // Beautiful terracotta flows matching style\n        opacity: 0.6,\n        widthMinPixels: 2.5,\n        trailLength: 450,\n        currentTime: time,\n      }),\n\n      // 2. Focused Site Aura Glow\n      ...(activeSelected\n        ? [\n            new ScatterplotLayer({\n              id: \'marker-selected-aura\',\n              data: [activeSelected],\n              getPosition: (d: any) => d.coords,\n              getRadius: 80,\n              radiusMinPixels: 14,\n              radiusMaxPixels: 35,\n              getFillColor: [146, 64, 14, 25], // Terracotta aura glow\n              stroked: true,\n              lineWidthMinPixels: 1.2,\n              getLineColor: [146, 64, 14, 140],\n            }),\n          ]\n        : []),\n\n      // 3. Miniaturized Thematic Pinpoint Markers\n      new ScatterplotLayer({\n        id: \'markers-primary\',\n        data: filtered,\n        getPosition: (d: any) => d.coords,\n        getFillColor: (d: any) => {\n          if (d.category === \'acqua\') return [14, 116, 144];      // Acquedotti - Ocean Blue\n          if (d.category === \'catacomba\') return [119, 23, 0];    // Necropoli - Classic Rust Accent\n          if (d.category === \'rifugio\') return [13, 148, 136];     // Rifugi - Deep Teal\n          return [146, 64, 14];                                   // Ipogei - Terracotta Primary\n        },\n        getRadius: 18,\n        radiusMinPixels: 5,\n        radiusMaxPixels: 10,\n        pickable: true,\n        stroked: true,\n        lineWidthMinPixels: 1.5,\n        getLineColor: (d: any) => {\n          if (activeSelected && d.id === activeSelected.id) {\n            return [58, 0, 0, 255]; // Deep wine borders for the active selection\n          }\n          return [255, 237, 221, 220]; // Cozy sand-parchment background boundary\n        },\n        onClick: (info: any) => {\n          if (info && info.object) {\n            onSelectSite(info.object);\n          }\n        },\n      }),\n\n      // 4. Elegant site titles\n      new TextLayer({\n        id: \'map-labels\',\n        data: filtered,\n        getPosition: (d: any) => d.coords,\n        getText: (d: any) => d.name.split(\' (\')[0],\n        getSize: 10,\n        getPixelOffset: [0, -16],\n        getColor: (d: any) => {\n          if (activeSelected && d.id === activeSelected.id) {\n            return [58, 0, 0, 255]; // Active text is solid high-contrast wine maroon\n          }\n          return [119, 23, 0, 190]; // Off-active is rust-accent brown\n        },\n        fontFamily: \'EB Garamond, serif\',\n        fontWeight: 600,\n        textAnchor: \'middle\',\n        alignmentBaseline: \'bottom\',\n      }),\n    ];\n\n    deckInstanceRef.current.setProps({ layers });\n  };\n\n  // Instantiation of DeckGL + MapLibre GL integration\n  useEffect(() => {\n    if (!mapContainerRef.current) return;\n    const { DeckGL } = (window as any).deck;\n    if (!DeckGL) return;\n\n    const deckInstance = new DeckGL({\n      container: mapContainerRef.current,\n      mapStyle: \'https://basemaps.cartocdn.com/gl/positron-gl-style/style.json\', // Antique light gray layout fits style image perfectly\n      maplibregl: (window as any).maplibregl, // Synchronize cameras correctly to eliminate coordinate shifting/drift\n      initialViewState: viewStateRef.current,\n      controller: true,\n      onViewStateChange: ({ viewState: vs }: any) => {\n        viewStateRef.current = vs;\n        updateLayers();\n      },\n      getCursor: ({ isHovering }: any) => (isHovering ? \'pointer\' : \'grab\'),\n      getTooltip: ({ object }: any) =>\n        object && {\n          html: `\n            <div style=\"font-family:\'EB Garamond\', serif; border-bottom: 1.5px solid #FFB580; padding-bottom: 6px; margin-bottom: 6px;\">\n              <span style=\"color:#3A0000; font-weight:700; font-size:15px\">${object.name}</span>\n            </div>\n            <div style=\"font-family:\'DM Mono\', monospace; font-size:11px; color:#92400E; display:flex; justify-content:space-between; gap:20px\">\n              <span>Profondit\303\240: <strong style=\"c