      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGGPJkXt6oUWufX_8nPA521vIAs5dFSVZoi6EB3RQXG8B2zI6wVbvoiT_rKTWVXjFwb6tGSy04TcrnGSxFbZ2laFFjTKb4Ly5sUDwXSXdZMegM5cb5p6FOjym918JFIFEHSwa9W_Y04gP7U_S8="
