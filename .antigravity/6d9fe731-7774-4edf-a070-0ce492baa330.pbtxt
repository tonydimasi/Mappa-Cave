        }
        lines {
          text: "  { id: 6, category: \'catacomba\', name: \'Cimitero delle Fontanelle\', coords: [14.238764, 40.858842], depth: 12, desc: \"Un\'immensa cava di tufo nel Rione Sanit\303\240 riconvertita in ossario dal XVII secolo. Luogo del culto delle \'anime pezzentelle\', \303\250 diviso in tre maestose navate (dei preti, degli appestati, dei pezzentelli).\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 7, category: \'catacomba\', name: \'Catacombe di San Gaudioso\', coords: [14.248420, 40.859850], depth: 10, desc: \"Situate sotto la Basilica di Santa Maria della Sanit\303\240, risalgono al V secolo d.C. Note per la pratica della \'scolatura\' dei cadaveri e gli affreschi parietali dove i crani reali dei defunti venivano incassati nel muro.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 8, category: \'ipogeo\', name: \'Ipogeo dei Cristallini\', coords: [14.253922, 40.857722], depth: 12, desc: \"Eccezionale testimonianza di necropoli ellenistica greca (fine IV - inizio III sec. a.C.) situata a 12 metri sotto il livello stradale nel Rione Sanit\303\240. Si compone di quattro tombe a camera con pitture murali intatte.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 9, category: \'rifugio\', name: \'Museo del Sottosuolo (Piazza Cavour)\', coords: [14.251340, 40.855210], depth: 25, desc: \"Sviluppato in cavit\303\240 originate dall\'estrazione del tufo e poi connesse all\'acquedotto della Bolla. Durante la WWII fu uno dei principali rifugi civili della citt\303\240. Oggi ospita eventi e rievocazioni dantesche.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 10, category: \'rifugio\', name: \'LAES - Napoli Sotterranea\', coords: [14.245890, 40.837340], depth: 35, desc: \"Percorso gestito dalla LAES che esplora il ventre dei Quartieri Spagnoli. Si scende in cavit\303\240 nate nel XVI secolo e trasformate in rifugi antiaerei bellici, con graffiti e resti degli arredi del periodo.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 11, category: \'acqua\', name: \'Lapis Museum\', coords: [14.254100, 40.850550], depth: 20, desc: \"Sotto la Basilica della Pietrasanta, espone i condotti degli acquedotti romani e le cisterne rinascimentali del sistema del Carmignano. Racconta millenni di ingegneria idraulica napoletana.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 12, category: \'ipogeo\', name: \'Ipogeo dei Togati\', coords: [14.251850, 40.857120], depth: 10, desc: \"Rara tomba greca a camera (fine IV sec. a.C.) situata a circa 10 metri sotto il livello stradale. Deve il nome a un raffinato bassorilievo che ritrae una coppia di coniugi defunti.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 13, category: \'ipogeo\', name: \'Mitreo di Carminiello ai Mannesi\', coords: [14.259800, 40.849500], depth: 7, desc: \"Area archeologica con impianto termale del I sec. d.C., trasformato in Mitreo nel II secolo d.C. Conserva il rilievo in stucco della \'tauroctonia\' (Mitra che uccide il toro).\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 14, category: \'rifugio\', name: \'Palazzo Cellammare (Rifugio)\', coords: [14.244320, 40.835850], depth: 22, desc: \"Sotto lo storico palazzo a Chiaia si estende una vasta rete di cavit\303\240 artificiali. Durante la guerra furono riadattate come rifugio antiaereo attrezzato per i residenti del quartiere.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 15, category: \'ipogeo\', name: \'Crypta Neapolitana\', coords: [14.217550, 40.829595], depth: 45, desc: \"Imponente galleria stradale romana lunga 705 metri (37 a.C.). Collegava Mergellina con Fuorigrotta ed \303\250 legata al mito di Virgilio Mago.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 16, category: \'ipogeo\', name: \'Fossa del Grano (Via Broggia)\', coords: [14.250890, 40.852450], depth: 14, desc: \"Serie di enormi cavit\303\240 scavate nel XVII secolo per lo stoccaggio pubblico dei cereali. Successivamente incorporate nella rete acquedottistica e rifugi WWII.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 17, category: \'ipogeo\', name: \'Teatro Romano (L\\\'Anticaglia)\', coords: [14.256250, 40.851650], depth: 5, desc: \"Resti del maestoso teatro di epoca romana imperiale dove cant\303\262 l\'imperatore Nerone. Le arcate della cavea sono oggi inglobate nel tessuto urbano moderno.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 18, category: \'ipogeo\', name: \'Ipogeo dei Melograni\', coords: [14.252320, 40.857450], depth: 11, desc: \"Sito archeologico della necropoli ellenistica della Sanit\303\240. Celebre per le decorazioni dipinte dedicate al melograno, simbolo dell\'aldil\303\240.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 19, category: \'acqua\', name: \'Acquedotto del Serino (Sottosuolo)\', coords: [14.258450, 40.851210], depth: 18, desc: \"Nota come \'Aqua Augusta\', monumentale opera idraulica romana lunga 80 km. I suoi condotti attraversano il sottosuolo cittadino a quote variabili.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 20, category: \'rifugio\', name: \'Ipogeo di Piazza Plebiscito\', coords: [14.248890, 40.835850], depth: 30, desc: \"Ambienti ipogei sotto la piazza monumentale. Intersecano la Galleria Borbonica e sono stati riadattati nei secoli per la distribuzione idrica.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 21, category: \'acqua\', name: \'Cavit\303\240 Via Avvocata 25\', coords: [14.244012, 40.852521], depth: 25, desc: \"Un\'estesa porzione dell\'antico sistema acquedottistico situata nel rione Avvocata. I rilievi indicano una superficie di 2.045 mq e una volumetria di 28.630 mc.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 22, category: \'ipogeo\', name: \'Complesso Via L. Bianchi\', coords: [14.218034, 40.871054], depth: 30, desc: \"Situato alla periferia nord, questo complesso \303\250 composto da tre ampie strutture ipogee collegate. Testimonia l\'attivit\303\240 di cava intensiva.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 23, category: \'ipogeo\', name: \'Cavit\303\240 Bosco Capodimonte 17/22\', coords: [14.255087, 40.867011], depth: 18, desc: \"Vasta cava adiacente al Real Bosco. Monitorata geotecnicamente per la stabilit\303\240 del piano stradale, esempio di attivit\303\240 estrattiva privata.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 24, category: \'ipogeo\', name: \'Cavit\303\240 Via F.M. Briganti\', coords: [14.267015, 40.868032], depth: 15, desc: \"Imponente complesso caveale con superficie di 2.500 mq. Uno dei vuoti artificiali pi\303\271 vasti della zona orientale, scavato per il prelievo di materiali edili.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 25, category: \'ipogeo\', name: \'Cavit\303\240 Vico della Calce 1\', coords: [14.242043, 40.856098], depth: 25, desc: \"Situata nel Rione Stella, con volume di 25.360 mc. Caratterizzata da una fitta maglia di pilastri residui per sostenere l\'abitato soprastante.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 26, category: \'ipogeo\', name: \'Cavit\303\240 Vico Calce Materdei 30\', coords: [14.241076, 40.853045], depth: 14, desc: \"Documenta la stratificazione delle attivit\303\240 estrattive private effettuate sotto i palazzi del XVII secolo a Materdei. Volume: 5.215 mc.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 27, category: \'ipogeo\', name: \'Cavit\303\240 Salita Vecchia Capodimonte 60\', coords: [14.250032, 40.862087], depth: 12, desc: \"Cava storica situata lungo l\'antico asse di collegamento verso la collina. Caratterizzata da pareti alte circa 10 metri e un soffitto piano.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 28, category: \'acqua\', name: \'Cisterna Piazza Cavour 74\', coords: [14.252098, 40.854521], depth: 8, desc: \"Ambiente idrico di accumulo situato sotto piazza Cavour. Faceva parte del sistema di distribuzione dell\'acquedotto della Bolla.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 29, category: \'ipogeo\', name: \'Cavit\303\240 Vico Centogradi ai Cristallini 10\', coords: [14.254512, 40.858043], depth: 15, desc: \"Una delle cavit\303\240 pi\303\271 imponenti censite tecnicamente nel quartiere Stella. Occupa una superficie di 6.478 mq e una volumetria di 64.780 mc.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 30, category: \'ipogeo\', name: \'Cavit\303\240 Via Chiaia 87\', coords: [14.246543, 40.837565], depth: 15, desc: \"Vasta cavit\303\240 tecnica situata sotto l\'asse stradale di via Chiaia. Testimonia l\'attivit\303\240 estrattiva tra XVII e XVIII secolo per i palazzi della nobilt\303\240.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 31, category: \'ipogeo\', name: \'Cavit\303\240 Via Chiaia 123\', coords: [14.245587, 40.836512], depth: 10, desc: \"Ulteriore ambiente ipogeo nel quartiere San Ferdinando. Cavit\303\240 \'di prestito\' scavata per l\'edificazione del quartiere tra il XVII e il XVIII secolo.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 32, category: \'ipogeo\', name: \'Cavit\303\240 Via Chiaia 179\', coords: [14.244512, 40.835543], depth: 10, desc: \"Ambiente ipogeo nel cuore di Chiaia. Il sito \303\250 censito per fini di controllo della stabilit\303\240 e monitoraggio delle infiltrazioni idriche profonde.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 33, category: \'ipogeo\', name: \'Cavit\303\240 Salita dei Cinesi 68\', coords: [14.253076, 40.861543], depth: 8, desc: \"Ex cava di tufo situata nel quartiere Stella, attualmente riutilizzata come autorimessa privata (garage).\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 34, category: \'ipogeo\', name: \'Cavit\303\240 Viale Colli Aminei 36\', coords: [14.242043, 40.872012], depth: 35, desc: \"Monumentale sistema di estrazione (oltre 206.000 mc). Una delle pi\303\271 grandi cave censite sulla collina.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 35, category: \'acqua\', name: \'Acquedotto Vico I Concezione\', coords: [14.245543, 40.844512], depth: 10, desc: \"Tratto di condotta idrica storica situata nei Quartieri Spagnoli. Documenta la densit\303\240 della rete di distribuzione ipogea seicentesca.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 36, category: \'ipogeo\', name: \'Cavit\303\240 Via Confalone 7\', coords: [14.238076, 40.851043], depth: 15, desc: \"Cava di modesta estensione situata nel quartiere Arenella. Testimonianza delle attivit\303\240 estrattive locali effettuate sui fianchi del Vomero.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 37, category: \'ipogeo\', name: \'Cavit\303\240 Via F.S. Correra 29\', coords: [14.247512, 40.850543], depth: 18, desc: \"Ampia cava nel rione Avvocata con superficie di 3.806 mq. Localizzata in area ad alta densit\303\240 abitativa.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 38, category: \'acqua\', name: \'Cisterna Via M. D\\\'Amelio 82\', coords: [14.223043, 40.858012], depth: 6, desc: \"Piccola camera idrica di accumulo situata nel quartiere Arenella. Faceva parte delle infrastrutture per l\'approvvigionamento dei casali.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 39, category: \'ipogeo\', name: \'Cava Pomici Via Forges Davanzati\', coords: [14.272512, 40.864543], depth: 4, desc: \"Nota popolarmente come \'tana di lapillo\', \303\250 un piccolo ambiente estrattivo scavato in terreni piroclastici incoerenti (pomici).\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 40, category: \'ipogeo\', name: \'Cavit\303\240 Via Carlo De Marco\', coords: [14.264012, 40.866543], depth: 6, desc: \"Cava censita nel quartiere San Carlo all\'Arena. Documenta l\'attivit\303\240 estrattiva eseguita lungo le pendici esterne di Capodimonte.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 41, category: \'acqua\', name: \'Calata San Mattia 23\', coords: [14.246410, 40.838350], depth: 40, desc: \"Custodisce il pi\303\271 grande tratto intatto dell\'acquedotto del Carmignano mai rinvenuto. Il sistema comprende 30 maestose cisterne alte 40 metri.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 42, category: \'acqua\', name: \'Palazzo Serra di Cassano\', coords: [14.245800, 40.835300], depth: 30, desc: \"Sito storico che integra condotte dell\'acquedotto rinascimentale e un rifugio antiaereo WWII sulla collina di Pizzofalcone.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 43, category: \'ipogeo\', name: \'Grotta di Seiano\', coords: [14.184310, 40.798150], depth: 45, desc: \"Tunnel stradale romano lungo 770 metri scavato nel I secolo a.C. sotto la collina di Posillipo. Accesso al Parco del Pausilypon.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 44, category: \'ipogeo\', name: \'Grotta di Cocceio\', coords: [14.053600, 40.839500], depth: 30, desc: \"Galleria militare romana che collegava il lago d\'Averno con Cuma. Parte integrante delle infrastrutture logistiche del Portus Julius.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 45, category: \'ipogeo\', name: \'Grotte Platomonie (Monte Echia)\', coords: [14.247800, 40.832200], depth: 10, desc: \"Antichissime cavit\303\240 ai piedi del Monte Echia. Fornirono il tufo per l\'edificazione dei primi borghi di Chiaia e delle mura meridionali.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 46, category: \'ipogeo\', name: \'Cavit\303\240 Via Vergini 19\', coords: [14.254500, 40.856500], depth: 25, desc: \"Cava monumentale con superficie di 437 mq. Rappresenta una prova della pressione estrattiva estrema subita dal sottosuolo della Sanit\303\240.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 47, category: \'acqua\', name: \'Cavit\303\240 Via Duomo 142\', coords: [14.258800, 40.850900], depth: 15, desc: \"Cisterna monumentale dell\'acquedotto greco-romano (Bolla). Presenta tracce storiche di riadattamento per il Convento dei Gerolomini.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 48, category: \'acqua\', name: \'Cavit\303\240 Vico Carlo Carafa 14\', coords: [14.246100, 40.843800], depth: 18, desc: \"Vasto sistema ipogeo che interseca condotte dell\'acquedotto e rifugi bellici. Soggetto a monitoraggio per fragilit\303\240 strutturale.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 49, category: \'acqua\', name: \'Cavit\303\240 Vico Carcere Sanfelice 7\', coords: [14.247200, 40.845600], depth: 20, desc: \"Complesso di cisterne dell\'acquedotto greco-romano con volume di 9.520 mc. Mostra segni di degrado nei rivestimenti in muratura.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 50, category: \'acqua\', name: \'Serbatoio Amedeo di Savoia\', coords: [14.250500, 40.865200], depth: 35, desc: \"Noto come \'Serbatoio AMAN\'. Imponente bacino di accumulo idrico profondo con una volumetria colossale di 371.925 mc.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 51, category: \'rifugio\', name: \'Trinit\303\240 degli Spagnoli 31\', coords: [14.247500, 40.838900], depth: 26, desc: \"Rifugio antiaereo monumentale (50.000 mc) ricavato da un antico acquedotto, accessibile tramite una scala di 135 gradini.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 52, category: \'ipogeo\', name: \'Via S. M. Antesaecula 126\', coords: [14.252000, 40.857100], depth: 12, desc: \"Tomba a camera greca distinta dall\'Ipogeo dei Togati. Testimonianza della necropoli ellenistica extra-moenia di Neapolis.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 53, category: \'acqua\', name: \'Cavit\303\240 Via Chiaia 216\', coords: [14.245800, 40.837800], depth: 28, desc: \"Vasta cavit\303\240 tecnica collegata al sistema idrico dei Quartieri Spagnoli. Uno dei vuoti artificiali pi\303\271 ampi documentati sotto Chiaia.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 54, category: \'ipogeo\', name: \'Via Arenaccia (Gussone)\', coords: [14.266500, 40.858500], depth: 28, desc: \"Sito stratigrafico identificato tramite sondaggi geologici profondi che hanno intercettato il banco di tufo a 28 metri.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 55, category: \'ipogeo\', name: \'Piazza S. Maria della Fede\', coords: [14.268200, 40.856800], depth: 38, desc: \"Sito di eccezionale interesse stratigrafico dove il tufo giallo viene intercettato a 38 metri dal piano campagna.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 56, category: \'acqua\', name: \'Cavit\303\240 Via Nicotera (Cisterna)\', coords: [14.245500, 40.836200], depth: 20, desc: \"Ambiente ipogeo appartenente all\'acquedotto del Carmignano. Caratterizzato da cisterne a quote differenziate per l\'attingimento.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 57, category: \'ipogeo\', name: \'Complesso dello Scudillo\', coords: [14.242100, 40.865500], depth: 45, desc: \"Il sistema caveale pi\303\271 maestoso di Napoli (838.000 mc). Durante la guerra fu enorme deposito di munizioni teatrale di un\'esplosione nel 1944.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 58, category: \'rifugio\', name: \'Giardino di Babuk (Cavit\303\240)\', coords: [14.258500, 40.856100], depth: 15, desc: \"Cavit\303\240 sotto un giardino nobiliare. Utilizzata come rifugio antiaereo e oggi sede di eventi culturali e spettacoli teatrali.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 59, category: \'acqua\', name: \'Piscina Mirabilis (Bacoli)\', coords: [14.081500, 40.795000], depth: 15, desc: \"Definita la \'Cattedrale dell\'Acqua\', terminale dell\'acquedotto Augusteo. Capacit\303\240 di 12.000 mc destinata alla flotta imperiale di Miseno.\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { id: 60, category: \'ipogeo\', name: \'Tombe a Forno di Materdei\', coords: [14.242500, 40.853500], depth: 6, desc: \"I pi\303\271 antichi esempi di cavit\303\240 artificiali di Napoli (4.500 anni fa), attribuiti alla cultura del Gaudo. Sepolture a camera scavate nel tufo.\" }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "export const TRIPS_DATA: Trip[] = ["
