    instruction: "Update scrollbar, tooltip, and badge colors in index.css for the premium light-parchment and maroon aesthetic"
    replacement_infos {
      original_chunk {
        target_content: "/* Base custom scrollbar styling */\n::-webkit-scrollbar {\n  width: 5px;\n  height: 5px;\n}\n\n::-webkit-scrollbar-track {\n  background: #0A0806;\n}\n\n::-webkit-scrollbar-thumb {\n  background: #8B6E2E;\n  border-radius: 2px;\n}\n\n::-webkit-scrollbar-thumb:hover {\n  background: #C9A84C;\n}\n\n/* Custom transitions and interactive feedback classes */\n.site-card-transition {\n  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);\n}\n\n.glow-classic-border {\n  border-color: rgba(201, 168, 76, 0.3);\n  box-shadow: 0 0 15px rgba(201,168,76,0.05);\n}\n\n.glow-classic-border:hover {\n  border-color: rgba(201, 168, 76, 0.6);\n  box-shadow: 0 0 25px rgba(201,168,76,0.12);\n}\n\n/* Deck.gl overlay configuration */\n.deck-tooltip {\n  background: #0A0806 !important;\n  border: 1px solid #C9A84C !important;\n  color: #F5EDD8 !important;\n  font-family: \'Playfair Display\', serif !important;\n  padding: 14px 18px !important;\n  border-radius: 0px !important;\n  font-size: 14px !important;\n  box-shadow: 0 10px 30px rgba(0,0,0,0.95) !important;\n  line-height: 1.5 !important;\n  max-width: 320px !important;\n  pointer-events: none !important;\n  text-align: left !important;\n  z-index: 999999 !important;\n}\n\n/* Custom styled badge helper */\n.badge-archaeology {\n  font-family: \'Inter\', sans-serif;\n  font-size: 9px;\n  letter-spacing: 0.15em;\n  text-transform: uppercase;\n  font-weight: 700;\n  padding: 3px 8px;\n  border-radius: 1px;\n  border: 1px solid currentColor;\n}"
        replacement_content: "/* Base custom scrollbar styling */\n::-webkit-scrollbar {\n  width: 6px;\n  height: 6px;\n}\n\n::-webkit-scrollbar-track {\n  background: #FFEDDD; /* brand-bg */\n}\n\n::-webkit-scrollbar-thumb {\n  background: #FFB580; /* brand-border */\n  border-radius: 3px;\n}\n\n::-webkit-scrollbar-thumb:hover {\n  background: #92400E; /* brand-primary */\n}\n\n/* Custom transitions and interactive feedback classes */\n.site-card-transition {\n  transition: all 0.25s cubic-bezier(0.2, 0.8, 0.2, 1);\n}\n\n.glow-classic-border {\n  border-color: rgba(146, 64, 14, 0.2);\n  box-shadow: 0 0 15px rgba(146, 64, 14, 0.03);\n}\n\n.glow-classic-border:hover {\n  border-color: rgba(146, 64, 14, 0.5);\n  box-shadow: 0 0 25px rgba(146, 64, 14, 0.08);\n}\n\n/* Deck.gl overlay configuration */\n.deck-tooltip {\n  background: #FFFFFF !important;\n  border: 2px solid #FFB580 !important;\n  color: #3A0000 !important;\n  font-family: \'EB Garamond\', serif !important;\n  padding: 12px 16px !important;\n  border-radius: 0px !important;\n  font-size: 14px !important;\n  box-shadow: 0 4px 20px rgba(58, 0, 0, 0.12) !important;\n  line-height: 1.4 !important;\n  max-width: 280px !important;\n  pointer-events: none !important;\n  text-align: left !important;\n  z-index: 999999 !important;\n}\n\n/* Custom styled badge helper */\n.badge-archaeology {\n  font-family: \'DM Mono\', monospace;\n  font-size: 9.5px;\n  letter-spacing: 0.1em;\n  text-transform: uppercase;\n  font-weight: 500;\n  padding: 2.5px 6.5px;\n  border-radius: 0px;\n  border: 1px solid currentColor;\n}"
      }
      num_matches: 1
    }
  }
