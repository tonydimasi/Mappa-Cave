    instruction: "Install style guide color theme and layout bug fixes on tab lists and details in App.tsx"
    replacement_infos {
      original_chunk {
        target_content: "  // Human category labels\n  const getCategoryTitle = (cat: string) => {\n    switch (cat) {\n      case \'acqua\':\n        return \'Acquedotti\';\n      case \'catacomba\':\n        return \'Necropoli\';\n      case \'rifugio\':\n        return \'Rifugi\';\n      case \'ipogeo\':\n        return \'Ipogei\';\n      default:\n        return \'Tutto\';\n    }\n  };\n\n  return (\n    <div className=\"flex w-screen h-screen relative bg-ink text-parchment font-sans overflow-hidden\">\n      {/* SIDEBAR (Fixed 420px width aligned with Design HTML) */}\n      <aside \n        id=\"ns-sidebar\" \n        className=\"w-[420px] h-full bg-ink border-r border-[#C9A84C]/40 flex flex-col z-20 text-[#F5EDD8] relative flex-shrink-0\"\n      >\n        {/* SIDEBAR HEADER */}\n        <header id=\"ns-header\" className=\"p-8 border-b border-[#C9A84C]/20 select-none\">\n          <div className=\"text-gold text-[10px] tracking-[0.3em] uppercase mb-2 font-sans font-bold\">\n            Progetto: Beta 1\n          </div>\n          <h1 id=\"ns-title\" className=\"text-4xl font-serif leading-tight\">\n            Sistema Geospaziale <span className=\"italic text-gold\">Unicum</span>\n          </h1>\n          <p className=\"mt-4 text-xs opacity-60 font-sans leading-relaxed\">\n            Catalogazione scientifica e mappatura dei complessi ipogei di Napoli. Esplorazione stratigrafica dell\'acquedotto e delle necropoli.\n          </p>\n        </header>\n\n        {/* INPUTS / TABS CONTROL CORNER (Styled like the template box #12100E) */}\n        <section className=\"px-8 py-6 bg-[#12100E] border-b border-gold/10\">\n          \n          {/* Tabs Filter Grid */}\n          <nav id=\"ns-tabs\" className=\"grid grid-cols-5 gap-1.5 mb-6 select-none\">\n            {([\'all\', \'acqua\', \'catacomba\', \'rifugio\', \'ipogeo\'] as const).map((cat) => (\n              <button\n                key={cat}\n                onClick={() => {\n                  setCategoryFilter(cat);\n                  setSelectedSite(null); // Clear selected for a pristine detail intro state\n                }}\n                className={`py-2 text-[9px] uppercase tracking-widest border transition-all cursor-pointer font-bold text-center flex flex-col items-center justify-center gap-1\n                  ${categoryFilter === cat\n                    ? \'border-gold bg-[#C9A84C] text-[#0A0806]\'\n                    : \'border-gold/30 text-gold hover:bg-[#C9A84C]/10\'\n                  }`}\n              >\n                <span className=\"text-[10px]\">\n                  {cat !== \'all\' ? (\n                    <CategoryIcon category={cat} size={11} />\n                  ) : (\n                    <Layers size={10} />\n                  )}\n                </span>\n                <span>{getCategoryTitle(cat)}</span>\n              </button>\n            ))}\n          </nav>\n\n          {/* Styled search input bottom line */}\n          <div className=\"relative\">\n            <input\n              type=\"text\"\n              value={searchQuery}\n              onChange={(e) => setSearchQuery(e.target.value)}\n              placeholder=\"Cerca sito archeologico...\"\n              className=\"w-full bg-transparent border-b border-[#C9A84C]/40 py-2.5 pr-8 text-sm focus:outline-none focus:border-[#C9A84C] placeholder:text-[#F5EDD8]/30 text-parchment outline-none font-sans\"\n            />\n            <div className=\"absolute right-0 top-3 opacity-40 text-gold\">\n              {searchQuery ? (\n                <button \n                  onClick={() => setSearchQuery(\'\')}\n                  className=\"hover:text-gold-light transition-colors\"\n                >\n                  <X size={14} />\n                </button>\n              ) : (\n                <Search size={14} />\n              )}\n            </div>\n          </div>\n        </section>\n\n        {/* STATIC GEOTECHNICAL LEDGER RATIOS */}\n        <div className=\"px-8 py-2.5 bg-black/40 border-b border-gold/10 flex items-center justify-between text-[11px] text-dust-light select-none font-sans\">\n          <div className=\"flex items-center gap-1.5\">\n            <Compass size={11} className=\"text-gold\" />\n            <span>Siti: <strong className=\"text-gold font-mono font-bold\">{stats.count}</strong></span>\n          </div>\n          <div className=\"flex items-center gap-1.5\">\n            <TrendingDown size={11} className=\"text-gold\" />\n            <span>Quanti: <strong className=\"text-gold font-mono font-bold\">-{stats.avgDepth}m</strong></span>\n          </div>\n          <div className=\"font-mono text-[9px] text-gold/60\">\n            N. Sotterraneo Beta 1\n          </div>\n        </div>\n\n        {/* SCROLLABLE SITES GRID LIST */}\n        <section \n          id=\"ns-list\" \n          className=\"flex-1 overflow-y-auto custom-scroll\"\n        >\n          {filteredSites.length > 0 ? (\n            filteredSites.map((site) => (\n              <SiteCard\n                key={site.id}\n                site={site}\n                isActive={selectedSite !== null && selectedSite.id === site.id}\n                onSelect={handleSelectSite}\n              />\n            ))\n          ) : (\n            <div className=\"p-10 text-center select-none\">\n              <BookOpen className=\"mx-auto w-10 h-10 stroke-[1.2] text-gold/45 mb-3 animate-pulse\" />\n              <p className=\"font-serif text-lg text-gold mb-1 font-semibold\">\n                Nessuna Cavit\303\240 Trovata\n              </p>\n              <p className=\"font-sans text-[12px] opacity-50 max-w-[240px] mx-auto leading-relaxed\">\n                Nessun fascicolo o reperto corrisponde ai parametri inseriti.\n              </p>\n            </div>\n          )}\n        </section>\n\n        {/* FIXED FOOTER REGISTRY BRANDING */}\n        <div className=\"p-4 bg-[#050403] text-[9.5px] text-center uppercase tracking-widest text-gold/40 border-t border-gold/10 font-mono select-none\">\n          Napoli Sotterranea \302\251 2026 - Registro Archeologico Digitale\n        </div>\n      </aside>\n\n      {/* COMPACT COMBINATION OF MAP & HIGH-CONTRAST PARCHMENT FOOTER DETAIL (Arranged for elite aesthetics) */}\n      <main className=\"flex-1 h-full flex flex-col relative bg-[#F5EDD8]\">\n        \n        {/* MAP DISPLAY FRAME (Restricting viewable height dynamically with CSS flex) */}\n        <section id=\"map-height-wrapper\" className=\"flex-1 relative overflow-hidden bg-black\">\n          <UndergroundMap\n            selectedSite={selectedSite}\n            categoryFilter={categoryFilter}\n            searchQuery={searchQuery}\n            onSelectSite={handleSelectSite}\n          />\n        </section>\n\n        {/* DETAILED HIGH-CONTRAST PARCHMENT REGISTER (Parchment bg, dark ink txt) */}\n        <footer \n          id=\"ns-detail\" \n          className=\"h-[250px] bg-[#F5EDD8] border-t-2 border-[#0A0806] flex relative z-10 text-[#0A0806] select-none\"\n        >\n          {/* LEFT CONTAINER (40% width, metadata summaries & simulated interactive utilities) */}\n          <div className=\"w-[40%] p-8 border-r border-[#0A0806]/10 flex flex-col justify-between h-full\">\n            <div>\n              <div className=\"flex items-center gap-3 mb-2.5 flex-wrap\">\n                <h2 id=\"det-name\" className=\"text-2xl font-serif font-bold text-[#0A0806] leading-tight truncate max-w-[240px]\" title={selectedSite ? selectedSite.name : \'Unicum\'}>\n                  {selectedSite ? selectedSite.name.split(\' (\')[0] : \'Sito non selezionato\'}\n                </h2>\n                <span className=\"px-2 py-0.5 bg-[#0A0806] text-[#C9A84C] text-[10px] uppercase font-mono font-bold tracking-wider mt-0.5\">\n                  {selectedSite ? getCategoryTitle(selectedSite.category) : \'Generale\'}\n                </span>\n              </div>\n\n              {/* Archeological Metrics indicators */}\n              <div className=\"flex gap-5 mt-4\">\n                <div className=\"flex flex-col\">\n                  <span className=\"text-[9px] uppercase opacity-50 font-bold tracking-wider\">Profondit\303\240</span>\n                  <span className=\"text-sm font-sans font-bold text-[#0A0806]\">\n                    {selectedSite ? `-${selectedSite.depth}.00` : \'\342\200\223\342\200\223\'} MT\n                  </span>\n                </div>\n                <div className=\"flex flex-col\">\n                  <span className=\"text-[9px] uppercase opacity-50 font-bold tracking-wider\">Umidit\303\240</span>\n                  <span className=\"text-sm font-sans font-bold text-[#0A0806]\">\n                    {selectedSite ? (selectedSite.depth > 20 ? \'88%\' : \'74%\') : \'\342\200\223\342\200\223\'}\n                  </span>\n                </div>\n                <div className=\"flex flex-col\">\n                  <span className=\"text-[9px] uppercase opacity-50 font-bold tracking-wider\">Stato</span>\n                  <span className=\"text-sm font-sans font-bold text-[#C9A84C] tracking-wide\">\n                    {selectedSite ? \'ISPEZIONABILE\' : \'STABILE\'}\n                  </span>\n                </div>\n              </div>\n            </div>\n\n            {/* Click actionable tactile layout trigger button */}\n            <button \n              onClick={() => {\n                if (selectedSite) {\n                  // Prompt showing real historical catalog coordinates\n                  alert(`Dispositivo di scansione 3D pronto sul sito:\\n${selectedSite.name}\\nCoordinate: ${selectedSite.coords[1]}\302\260 N, ${selectedSite.coords[0]}\302\260 E`);\n                } else {\n                  alert(\"Seleziona una cavit\303\240 sotterranea nel menu per inizializzare il modello tridimensionale.\");\n                }\n              }}\n              className=\"border border-[#0A0806] px-5 py-2 text-xs uppercase tracking-widest font-bold hover:bg-[#0A0806] hover:text-[#F5EDD8] cursor-pointer transition-all self-start\"\n            >\n              Visualizza Rilievo 3D\n            </button>\n          </div>\n          \n          {/* RIGHT CONTAINER (Dossier narrative with luxury serif alignment) */}\n          <div className=\"flex-1 p-8 overflow-y-auto custom-scroll bg-gradient-to-r from-transparent to-[#C9A84C]/5 flex flex-col\">\n            <h4 className=\"text-[10px] uppercase tracking-widest opacity-40 mb-3 font-mono font-bold\">\n              Dossier Tecnico / Archivio Storico\n            </h4>\n            <p id=\"det-desc\" className=\"text-[13.5px] leading-relaxed text-[#0A0806]/80 font-serif text-justify overflow-y-auto pr-1\">\n              {selectedSite \n                ? selectedSite.desc \n                : \"Il Sistema Geospaziale Unicum costituisce la mappatura ufficiale delle cavit\303\240 ipogee e dei condotti idrici storici della citt\303\240 di Napoli. Esplora il catalogo di 60 complesses archeologici mediante i filtri tipologici o seleziona un punto sulla mappa orbitale tridimensionale per consultare la sismologia, la stratigrafia e i metri esatti di profondit\303\240 dal piano stradale.\"}\n            </p>\n          </div>\n        </footer>\n      </main>\n    </div>\n  );\n}"
        replacement_content: "  // Human category labels\n  const getCategoryTitle = (cat: string) => {\n    switch (cat) {\n      case \'acqua\':\n        return \'Acqua\';\n      case \'catacomba\':\n        return \'Cripte\';\n      case \'rifugio\':\n        return \'Rifugi\';\n      case \'ipogeo\':\n        return \'Ipogei\';\n      default:\n        return \'Tutto\';\n    }\n  };\n\n  const getCategoryShortLabel = (cat: string) => {\n    switch (cat) {\n      case \'acqua\':\n        return \'Acquedotto\';\n      case \'catacomba\':\n        return \'Necropoli\';\n      case \'rifugio\':\n        return \'Rifugio WWII\';\n      case \'ipogeo\':\n        return \'Ipogeo Ellenico\';\n      default:\n        return \'Generale\';\n    }\n  };\n\n  return (\n    <div className=\"flex w-screen h-screen relative bg-brand-bg text-brand-text font-sans overflow-hidden\">\n      {/* SIDEBAR (Fixed 420px width aligned with Design HTML / style card) */}\n      <aside \n        id=\"ns-sidebar\" \n        className=\"w-[420px] h-full bg-brand-bg border-r border-brand-border/40 flex flex-col z-20 text-brand-text relative flex-shrink-0\"\n      >\n        {/* SIDEBAR HEADER */}\n        <header id=\"ns-header\" className=\"p-8 border-b border-brand-border/30 select-none\">\n          <div className=\"text-brand-primary text-[10px] tracking-[0.3em] uppercase mb-2 font-mono font-bold\">\n            Progetto: Beta 1\n          </div>\n          <h1 id=\"ns-title\" className=\"text-4xl font-serif leading-tight font-extrabold\">\n            Sistema Geospaziale <span className=\"italic text-brand-primary\">Unicum</span>\n          </h1>\n          <p className=\"mt-4 text-xs opacity-75 font-sans leading-relaxed text-brand-text/80\">\n            Catalogazione scientifica e mappatura dei complessi ipogei di Napoli. Esplorazione stratigrafica dell\'acquedotto e delle necropoli.\n          </p>\n        </header>\n\n        {/* INPUTS / TABS CONTROL CORNER (Styled matching image color palette) */}\n        <section className=\"px-8 py-6 bg-brand-surface border-b border-brand-border/30\">\n          \n          {/* Tabs Filter Grid - Highly optimized short labels to fit the narrow space perfectly */}\n          <nav id=\"ns-tabs\" className=\"grid grid-cols-5 gap-1.5 mb-6 select-none font-mono\">\n            {([\'all\', \'acqua\', \'catacomba\', \'rifugio\', \'ipogeo\'] as const).map((cat) => (\n              <button\n                key={cat}\n                onClick={() => {\n                  setCategoryFilter(cat);\n                  setSelectedSite(null); // Clear selected for a pristine detail intro state\n                }}\n                className={`py-2 text-[9px] uppercase tracking-wider border transition-all cursor-pointer font-bold text-center flex flex-col items-center justify-center gap-1 rounded-none\n                  ${categoryFilter === cat\n                    ? \'border-brand-primary bg-brand-primary text-white\'\n                    : \'border-brand-border/50 text-brand-primary hover:bg-brand-primary/10\'\n                  }`}\n              >\n                <span className=\"text-[10px]\">\n                  {cat !== \'all\' ? (\n                    <CategoryIcon category={cat} size={11} />\n                  ) : (\n                    <Layers size={10} />\n                  )}\n                </span>\n                <span className=\"text-[9px] truncate w-full\">{getCategoryTitle(cat)}</span>\n              </button>\n            ))}\n          </nav>\n\n          {/* Styled search input bottom line */}\n          <div className=\"relative\">\n            <input\n              type=\"text\"\n              value={searchQuery}\n              onChange={(e) => setSearchQuery(e.target.value)}\n              placeholder=\"Cerca sito archeologico...\"\n              className=\"w-full bg-transparent border-b border-brand-border py-2.5 pr-8 text-sm focus:outline-none focus:border-brand-primary placeholder:text-brand-text/30 text-brand-text outline-none font-sans\"\n            />\n            <div className=\"absolute right-0 top-3 opacity-60 text-brand-primary\">\n              {searchQuery ? (\n                <button \n                  onClick={() => setSearchQuery(\'\')}\n                  className=\"hover:text-brand-accent transition-colors\"\n                >\n                  <X size={14} />\n                </button>\n              ) : (\n                <Search size={14} />\n              )}\n            </div>\n          </div>\n        </section>\n\n        {/* STATIC GEOTECHNICAL LEDGER RATIOS */}\n        <div className=\"px-8 py-3 bg-brand-bg border-b border-brand-border/30 flex items-center justify-between text-[11px] text-brand-text/80 select-none font-sans\">\n          <div className=\"flex items-center gap-1.5\">\n            <Compass size={11} className=\"text-brand-primary\" />\n            <span>Siti: <strong className=\"text-brand-accent font-mono font-bold\">{stats.count}</strong></span>\n          </div>\n          <div className=\"flex items-center gap-1.5 flex-1 justify-center\">\n            <TrendingDown size={11} className=\"text-brand-primary\" />\n            <span>Quota Media: <strong className=\"text-brand-accent font-mono font-bold\">-{stats.avgDepth}m</strong></span>\n          </div>\n          <div className=\"font-mono text-[9px] text-brand-primary/60 font-semibold\">\n            REGISTRO GENERALE\n          </div>\n        </div>\n\n        {/* SCROLLABLE SITES GRID LIST */}\n        <section \n          id=\"ns-list\" \n          className=\"flex-1 overflow-y-auto custom-scroll bg-brand-surface/20\"\n        >\n          {filteredSites.length > 0 ? (\n            filteredSites.map((site) => (\n              <SiteCard\n                key={site.id}\n                site={site}\n                isActive={selectedSite !== null && selectedSite.id === site.id}\n                onSelect={handleSelectSite}\n              />\n            ))\n          ) : (\n            <div className=\"p-10 text-center select-none\">\n              <BookOpen className=\"mx-auto w-10 h-10 stroke-[1.2] text-brand-primary/30 mb-3 animate-pulse\" />\n              <p className=\"font-serif text-lg text-brand-text/80 mb-1 font-bold\">\n                Nessun Reperto\n              </p>\n              <p className=\"font-sans text-[12px] opacity-60 max-w-[240px] mx-auto leading-relaxed\">\n                Nessun fascicolo o reperto corrisponde ai parametri inseriti.\n              </p>\n            </div>\n          )}\n        </section>\n\n        {/* FIXED FOOTER REGISTRY BRANDING */}\n        <div className=\"p-4 bg-brand-bg text-[9.5px] text-center uppercase tracking-widest text-brand-text/60 border-t border-brand-border/25 font-mono select-none font-semibold\">\n          Napoli Sotterranea \302\251 2026 \302\267 Registro Geocentrico\n        </div>\n      </aside>\n\n      {/* COMPACT COMBINATION OF MAP & HIGH-CONTRAST PARCHMENT FOOTER DETAIL */}\n      <main className=\"flex-1 h-full flex flex-col relative bg-brand-bg\">\n        \n        {/* MAP DISPLAY FRAME */}\n        <section id=\"map-height-wrapper\" className=\"flex-1 relative overflow-hidden bg-white\">\n          <UndergroundMap\n            selectedSite={selectedSite}\n            categoryFilter={categoryFilter}\n            searchQuery={searchQuery}\n            onSelectSite={handleSelectSite}\n          />\n        </section>\n\n        {/* DETAILED HIGH-CONTRAST REGISTER (Parchment bg, dark ink txt) */}\n        <footer \n          id=\"ns-detail\" \n          className=\"h-[250px] bg-brand-bg border-t-2 border-brand-text flex relative z-10 text-brand-text select-none\"\n        >\n          {/* LEFT CONTAINER (40% width, metadata summaries) */}\n          <div className=\"w-[40%] p-8 border-r border-brand-border/40 flex flex-col justify-between h-full\">\n            <div>\n              <div className=\"flex items-center gap-3 mb-2.5 flex-wrap\">\n                <h2 id=\"det-name\" className=\"text-2xl font-serif font-extrabold text-brand-text leading-tight truncate max-w-[240px]\" title={selectedSite ? selectedSite.name : \'Unicum\'}>\n                  {selectedSite ? selectedSite.name.split(\' (\')[0] : \'Sito non selezionato\'}\n                </h2>\n                <span className=\"px-2 py-0.5 bg-brand-primary text-white text-[9px] uppercase font-mono font-bold tracking-wider mt-0.5\">\n                  {selectedSite ? getCategoryShortLabel(selectedSite.category) : \'Generale\'}\n                </span>\n              </div>\n\n              {/* Archeological Metrics indicators */}\n              <div className=\"flex gap-5 mt-4\">\n                <div className=\"flex flex-col\">\n                  <span className=\"text-[9px] uppercase opacity-60 font-bold tracking-wider font-mono\">Profondit\303\240</span>\n                  <span className=\"text-sm font-sans font-extrabold text-brand-text\">\n                    {selectedSite ? `-${selectedSite.depth}.00` : \'\342\200\223\342\200\223\'} MT\n                  </span>\n                </div>\n                <div className=\"flex flex-col\">\n                  <span className=\"text-[9px] uppercase opacity-60 font-bold tracking-wider font-mono\">Umidit\303\240</span>\n                  <span className=\"text-sm font-sans font-extrabold text-brand-text\">\n                    {selectedSite ? (selectedSite.depth > 20 ? \'88%\' : \'74%\') : \'\342\200\223\342\200\223\'}\n                  </span>\n                </div>\n                <div className=\"flex flex-col\">\n                  <span className=\"text-[9px] uppercase opacity-60 font-bold tracking-wider font-mono\">Stato</span>\n                  <span className=\"text-sm font-sans font-extrabold text-brand-accent tracking-wide\">\n                    {selectedSite ? \'ISPEZIONABILE\' : \'STABILE\'}\n                  </span>\n                </div>\n              </div>\n            </div>\n\n            {/* Click actionable tactile layout trigger button */}\n            <button \n              onClick={() => {\n                if (selectedSite) {\n                  // Prompt showing real historical catalog coordinates\n                  alert(`Dispositivo di scansione 3D pronto sul sito:\\n${selectedSite.name}\\nCoordinate: ${selectedSite.coords[1]}\302\260 N, ${selectedSite.coords[0]}\302\260 E`);\n                } else {\n                  alert(\"Seleziona una cavit\303\240 sotterranea nel menu per inizializzare il modello tridimensionale.\");\n                }\n              }}\n              className=\"border border-brand-text bg-brand-surface hover:bg-brand-primary hover:text-white px-5 py-2 text-xs uppercase tracking-widest font-bold cursor-pointer transition-all self-start text-brand-text\"\n            >\n              Visualizza Rilievo 3D\n            </button>\n          </div>\n          \n          {/* RIGHT CONTAINER (Dossier narrative with luxury serif alignment) */}\n          <div className=\"flex-1 p-8 overflow-y-auto custom-scroll bg-gradient-to-r from-transparent to-brand-border/10 flex flex-col\">\n            <h4 className=\"text-[10px] uppercase tracking-widest opacity-60 mb-2 font-mono font-bold text-brand-primary\">\n              Dossier Tecnico / Archivio Storico\n            </h4>\n            <p id=\"det-desc\" className=\"text-[15.5px] leading-relaxed text-brand-text/90 font-serif text-justify overflow-y-auto pr-1\">\n              {selectedSite \n                ? selectedSite.desc \n                : \"Il Sistema Geospaziale Unicum costituisce la mappatura ufficiale delle cavit\303\240 ipogee e dei condotti idrici storici della citt\303\240 di Napoli. Esplora il catalogo di Complesso Napoli Sotterranea mediante i filtri tipologici superiori o seleziona un punto sulla mappa orbitale tridimensionale per consultare la sismologia, la stratigrafia e i metri esatti di profondit\303\240 dal piano stradale.\"}\n            </p>\n          </div>\n        </footer>\n      </main>\n    </div>\n  );\n}"
      }
      fuzzy_match: "  // Human category labels\n  const getCategoryTitle = (cat: string) => {\n    switch (cat) {\n      case \'acqua\':\n        return \'Acquedotti\';\n      case \'catacomba\':\n        return \'Necropoli\';\n      case \'rifugio\':\n        return \'Rifugi\';\n      case \'ipogeo\':\n        return \'Ipogei\';\n      default:\n        return \'Tutto\';\n    }\n  };\n\n  return (\n    <div className=\"flex w-screen h-screen relative bg-ink text-parchment font-sans overflow-hidden\">\n      {/* SIDEBAR (Fixed 420px width aligned with Design HTML) */}\n      <aside \n        id=\"ns-sidebar\" \n        className=\"w-[420px] h-full bg-ink border-r border-[#C9A84C]/40 flex flex-col z-20 text-[#F5EDD8] relative flex-shrink-0\"\n      >\n        {/* SIDEBAR HEADER */}\n        <header id=\"ns-header\" className=\"p-8 border-b border-[#C9A84C]/20 select-none\">\n          <div className=\"text-gold text-[10px] tracking-[0.3em] uppercase mb-2 font-sans font-bold\">\n            Progetto: Beta 1\n          </div>\n          <h1 id=\"ns-title\" className=\"text-4xl font-serif leading-tight\">\n            Sistema Geospaziale <span className=\"italic text-gold\">Unicum</span>\n          </h1>\n          <p className=\"mt-4 text-xs opacity-60 font-sans leading-relaxed\">\n            Catalogazione scientifica e mappatura dei complessi ipogei di Napoli. Esplorazione stratigrafica dell\'acquedotto e delle necropoli.\n          </p>\n        </header>\n\n        {/* INPUTS / TABS CONTROL CORNER (Styled like the template box #12100E) */}\n        <section className=\"px-8 py-6 bg-[#12100E] border-b border-gold/10\">\n          \n          {/* Tabs Filter Grid */}\n          <nav id=\"ns-tabs\" className=\"grid grid-cols-5 gap-1.5 mb-6 select-none\">\n            {([\'all\', \'acqua\', \'catacomba\', \'rifugio\', \'ipogeo\'] as const).map((cat) => (\n              <button\n                key={cat}\n                onClick={() => {\n                  setCategoryFilter(cat);\n                  setSelectedSite(null); // Clear selected for a pristine detail intro state\n                }}\n                className={`py-2 text-[9px] uppercase tracking-widest border transition-all cursor-pointer font-bold text-center flex flex-col items-center justify-center gap-1\n                  ${categoryFilter === cat\n                    ? \'border-gold bg-[#C9A84C] text-[#0A0806]\'\n                    : \'border-gold/30 text-gold hover:bg-[#C9A84C]/10\'\n                  }`}\n              >\n                <span className=\"text-[10px]\">\n                  {cat !== \'all\' ? (\n                    <CategoryIcon category={cat} size={11} />\n                  ) : (\n                    <Layers size={10} />\n                  )}\n                </span>\n                <span>{getCategoryTitle(cat)}</span>\n              </button>\n            ))}\n          </nav>\n\n          {/* Styled search input bottom line */}\n          <div className=\"relative\">\n            <input\n              type=\"text\"\n              value={searchQuery}\n              onChange={(e) => setSearchQuery(e.target.value)}\n              placeholder=\"Cerca sito archeologico...\"\n              className=\"w-full bg-transparent border-b border-[#C9A84C]/40 py-2.5 pr-8 text-sm focus:outline-none focus:border-[#C9A84C] placeholder:text-[#F5EDD8]/30 text-parchment outline-none font-sans\"\n            />\n            <div className=\"absolute right-0 top-3 opacity-40 text-gold\">\n              {searchQuery ? (\n                <button \n                  onClick={() => setSearchQuery(\'\')}\n                  className=\"hover:text-gold-light transition-colors\"\n                >\n                  <X size={14} />\n                </button>\n              ) : (\n                <Search size={14} />\n              )}\n            </div>\n          </div>\n        </section>\n\n        {/* STATIC GEOTECHNICAL LEDGER RATIOS */}\n        <div className=\"px-8 py-2.5 bg-black/40 border-b border-gold/10 flex items-center justify-between text-[11px] text-dust-light select-none font-sans\">\n          <div className=\"flex items-center gap-1.5\">\n            <Compass size={11} className=\"text-gold\" />\n            <span>Siti: <strong className=\"text-gold font-mono font-bold\">{stats.count}</strong></span>\n          </div>\n          <div className=\"flex items-center gap-1.5\">\n            <TrendingDown size={11} className=\"text-gold\" />\n            <span>Quanti: <strong className=\"text-gold font-mono font-bold\">-{stats.avgDepth}m</strong></span>\n          </div>\n          <div className=\"font-mono text-[9px] text-gold/60\">\n            N. Sotterraneo Beta 1\n          </div>\n        </div>\n\n        {/* SCROLLABLE SITES GRID LIST */}\n        <section \n          id=\"ns-list\" \n          className=\"flex-1 overflow-y-auto custom-scroll\"\n        >\n          {filteredSites.length > 0 ? (\n            filteredSites.map((site) => (\n              <SiteCard\n                key={site.id}\n                site={site}\n                isActive={selectedSite !== null && selectedSite.id === site.id}\n                onSelect={handleSelectSite}\n              />\n            ))\n          ) : (\n            <div className=\"p-10 text-center select-none\">\n              <BookOpen className=\"mx-auto w-10 h-10 stroke-[1.2] text-gold/45 mb-3 animate-pulse\" />\n              <p className=\"font-serif text-lg text-gold mb-1 font-semibold\">\n                Nessuna Cavit\303\240 Trovata\n              </p>\n              <p className=\"font-sans text-[12px] opacity-50 max-w-[240px] mx-auto leading-relaxed\">\n                Nessun fascicolo o reperto corrisponde ai parametri inseriti.\n              </p>\n            </div>\n          )}\n        </section>\n\n        {/* FIXED FOOTER REGISTRY BRANDING */}\n        <div className=\"p-4 bg-[#050403] text-[9.5px] text-center uppercase tracking-widest text-gold/40 border-t border-gold/10 font-mono select-none\">\n          Napoli Sotterranea \302\251 2026 - Registro Archeologico Digitale\n        </div>\n      </aside>\n\n      {/* COMPACT COMBINATION OF MAP & HIGH-CONTRAST PARCHMENT FOOTER DETAIL (Arranged for elite aesthetics) */}\n      <main className=\"flex-1 h-full flex flex-col relative bg-[#F5EDD8]\">\n        \n        {/* MAP DISPLAY FRAME (Restricting viewable height dynamically with CSS flex) */}\n        <section id=\"map-height-wrapper\" className=\"flex-1 relative overflow-hidden bg-black\">\n          <UndergroundMap\n            selectedSite={selectedSite}\n            categoryFilter={categoryFilter}\n            searchQuery={searchQuery}\n            onSelectSite={handleSelectSite}\n          />\n        </section>\n\n        {/* DETAILED HIGH-CONTRAST PARCHMENT REGISTER (Parchment bg, dark ink txt) */}\n        <footer \n          id=\"ns-detail\" \n          className=\"h-[250px] bg-[#F5EDD8] border-t-2 border-[#0A0806] flex relative z-10 text-[#0A0806] select-none\"\n        >\n          {/* LEFT CONTAINER (40% width, metadata summaries & simulated interactive utilities) */}\n          <div className=\"w-[40%] p-8 border-r border-[#0A0806]/10 flex flex-col justify-between h-full\">\n            <div>\n              <div className=\"flex items-center gap-3 mb-2.5 flex-wrap\">\n                <h2 id=\"det-name\" className=\"text-2xl font-serif font-bold text-[#0A0806] leading-tight truncate max-w-[240px]\" title={selectedSite ? selectedSite.name : \'Unicum\'}>\n                  {selectedSite ? selectedSite.name.split(\' (\')[0] : \'Sito non selezionato\'}\n                </h2>\n                <span className=\"px-2 py-0.5 bg-[#0A0806] text-[#C9A84C] text-[10px] uppercase font-mono font-bold tracking-wider mt-0.5\">\n                  {selectedSite ? getCategoryTitle(selectedSite.category) : \'Generale\'}\n                </span>\n              </div>\n\n              {/* Archeological Metrics indicators */}\n              <div className=\"flex gap-5 mt-4\">\n                <div className=\"flex flex-col\">\n                  <span className=\"text-[9px] uppercase opacity-50 font-bold tracking-wider\">Profondit\303\240</span>\n                  <span className=\"text-sm font-sans font-bold text-[#0A0806]\">\n                    {selectedSite ? `-${selectedSite.depth}.00` : \'\342\200\223\342\200\223\'} MT\n                  </span>\n                </div>\n                <div className=\"flex flex-col\">\n                  <span className=\"text-[9px] uppercase opacity-50 font-bold tracking-wider\">Umidit\303\240</span>\n                  <span className=\"text-sm font-sans font-bold text-[#0A0806]\">\n                    {selectedSite ? (selectedSite.depth > 20 ? \'88%\' : \'74%\') : \'\342\200\223\342\200\223\'}\n                  </span>\n                </div>\n                <div className=\"flex flex-col\">\n                  <span className=\"text-[9px] uppercase opacity-50 font-bold tracking-wider\">Stato</span>\n                  <span className=\"text-sm font-sans font-bold text-[#C9A84C] tracking-wide\">\n                    {selectedSite ? \'ISPEZIONABILE\' : \'STABILE\'}\n                  </span>\n                </div>\n              </div>\n            </div>\n\n            {/* Click actionable tactile layout trigger button */}\n            <button \n              onClick={() => {\n                if (selectedSite) {\n                  // Prompt showing real historical catalog coordinates\n                  alert(`Dispositivo di scansione 3D pronto sul sito:\\n${selectedSite.name}\\nCoordinate: ${selectedSite.coords[1]}\302\260 N, ${selectedSite.coords[0]}\302\260 E`);\n                } else {\n                  alert(\"Seleziona una cavit\303\240 sotterranea nel menu per inizializzare il modello tridimensionale.\");\n                }\n              }}\n              className=\"border border-[#0A0806] px-5 py-2 text-xs uppercase tracking-widest font-bold hover:bg-[#0A0806] hover:text-[#F5EDD8] cursor-pointer transition-all self-start\"\n            >\n              Visualizza Rilievo 3D\n            </button>\n          </div>\n          \n          {/* RIGHT CONTAINER (Dossier narrative with luxury serif alignment) */}\n          <div className=\"flex-1 p-8 overflow-y-auto custom-scroll bg-gradient-to-r from-transparent to-[#C9A84C]/5 flex flex-col\">\n            <h4 className=\"text-[10px] uppercase tracking-widest opacity-40 mb-3 font-mono font-bold\">\n              Dossier Tecnico / Archivio Storico\n            </h4>\n            <p id=\"det-desc\" className=\"text-[13.5px] leading-relaxed text-[#0A0806]/80 font-serif text-justify overflow-y-auto pr-1\">\n              {selectedSite \n                ? selectedSite.desc \n                : \"Il Sistema Geospaziale Unicum costituisce la mappatura ufficiale delle cavit\303\240 ipogee e dei condotti idrici storici della citt\303\240 di Napoli. Esplora il catalogo di 60 complessi archeologici mediante i filtri tipologici o seleziona un punto sulla mappa orbitale tridimensionale per consultare la sismologia, la stratigrafia e i metri esatti di profondit\303\240 dal piano stradale.\"}\n            </p>\n          </div>\n        </footer>\n      </main>"
