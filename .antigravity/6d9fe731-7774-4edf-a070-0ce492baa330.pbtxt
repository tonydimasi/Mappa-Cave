  file_change {
    absolute_path_uri: "file:///src/data.ts"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { Site, Trip } from \'./types.ts\';\n\nexport const SITES_DATA: Site[] = [\n  { id: 1, category: \'acqua\', name: \'Napoli Sotterranea (Piazza San Gaetano)\', coords: [14.256050, 40.850785], depth: 40, desc: \"Situato a 40 metri di profondit\303\240 sotto il cuore pulsante del centro storico, questo sito rappresenta la stratificazione di 2.400 anni di storia napoletana. Il percorso permette di esplorare i cunicoli e le imponenti cisterne del sistema idrico greco-romano. Durante la Seconda Guerra Mondiale, queste cavit\303\240 furono riconvertite in rifugi antiaerei dal Genio Militare. Include l\'accesso ai resti del Teatro Romano.\" },\n  { id: 2, category: \'rifugio\', name: \'Galleria Borbonica (Tunnel Borbonico)\', coords: [14.246272, 40.835472], depth: 35, desc: \"Progettata nel 1853 dall\'architetto Errico Alvino per volont\303\240 di Ferdinando II di Borbone, l\'opera doveva essere un viadotto militare per collegare il Palazzo Reale con le caserme di Chiaia. Il traforo attraversa enormi cave di tufo giallo del XVI secolo e interseca le cisterne dell\'acquedotto della Bolla. Oggi conserva carcasse di auto, moto d\'epoca e statue monumentali.\" },\n  { id: 3, category: \'ipogeo\', name: \'Neapolis Sotterrata (S. Lorenzo)\', coords: [14.256850, 40.850720], depth: 6, desc: \"L\'area archeologica situata sotto la Basilica di San Lorenzo Maggiore rivela l\'antico Foro Romano di Neapolis, costruito sopra l\'agor\303\240 greca. A circa 6 metri di profondit\303\240, i visitatori possono percorrere l\'antico cardo stradale e osservare i resti del Macellum con le sue tabernae.\" },\n  { id: 4, category: \'ipogeo\', name: \'Cappella Sansevero (Cripta)\', coords: [14.254881, 40.849189], depth: 8, desc: \"Progettata nel XVIII secolo dal principe Raimondo di Sangro come mausoleo familiare. Questa camera ipogea a pianta ellittica custodisce oggi le \'Macchine Anatomiche\': due corpi umani che mostrano l\'intero sistema circolatorio ricostruito con precisione millimetrica.\" },\n  { id: 5, category: \'catacomba\', name: \'Catacombe di San Gennaro\', coords: [14.247625, 40.864181], depth: 15, desc: \"Il pi\303\271 importante monumento del Cristianesimo a Napoli. Disposte su due livelli scavati nella roccia tufacea, il loro nucleo risale al II-III secolo d.C. Divennero centro di culto universale dopo la traslazione dei resti di San Gennaro nel V secolo.\" },\n  { id: 6, category: \'catacomba\', name: \'Cimitero delle Fontanelle\', coords: [14.238764, 40.858842], depth: 12, desc: \"Un\'immensa cava di tufo nel Rione Sanit\303\240 riconvertita in ossario dal XVII secolo. Luogo del culto delle \'anime pezzentelle\', \303\250 diviso in tre maestose navate (dei preti, degli appestati, dei pezzentelli).\" },\n  { id: 7, category: \'catacomba\', name: \'Catacombe di San Gaudioso\', coords: [14.248420, 40.859850], depth: 10, desc: \"Situate sotto la Basilica di Santa Maria della Sanit\303\240, risalgono al V secolo d.C. Note per la pratica della \'scolatura\' dei cadaveri e gli affreschi parietali dove i crani reali dei defunti venivano incassati nel muro.\" },\n  { id: 8, category: \'ipogeo\', name: \'Ipogeo dei Cristallini\', coords: [14.253922, 40.857722], depth: 12, desc: \"Eccezionale testimonianza di necropoli ellenistica greca (fine IV - inizio III sec. a.C.) situata a 12 metri sotto il livello stradale nel Rione Sanit\303\240. Si compone di quattro tombe a camera con pitture murali intatte.\" },\n  { id: 9, category: \'rifugio\', name: \'Museo del Sottosuolo (Piazza Cavour)\', coords: [14.251340, 40.855210], depth: 25, desc: \"Sviluppato in cavit\303\240 originate dall\'estrazione del tufo e poi connesse all\'acquedotto della Bolla. Durante la WWII fu uno dei principali rifugi civili della citt\303\240. Oggi ospita eventi e rievocazioni dantesche.\" },\n  { id: 10, category: \'rifugio\', name: \'LAES - Napoli Sotterranea\', coords: [14.245890, 40.837340], depth: 35, desc: \"Percorso gestito dalla LAES che esplora il ventre dei Quartieri Spagnoli. Si scende in cavit\303\240 nate nel XVI secolo e trasformate in rifugi antiaerei bellici, con graffiti e resti degli arredi del periodo.\" },\n  { id: 11, category: \'acqua\', name: \'Lapis Museum\', coords: [14.254100, 40.850550], depth: 20, desc: \"Sotto la Basilica della Pietrasanta, espone i condotti degli acquedotti romani e le cisterne rinascimentali del sistema del Carmignano. Racconta millenni di ingegneria idraulica napoletana.\" },\n  { id: 12, category: \'ipogeo\', name: \'Ipogeo dei Togati\', coords: [14.251850, 40.857120], depth: 10, desc: \"Rara tomba greca a camera (fine IV sec. a.C.) situata a circa 10 metri sotto il livello stradale. Deve il nome a un raffinato bassorilievo che ritrae una coppia di coniugi defunti.\" },\n  { id: 13, category: \'ipogeo\', name: \'Mitreo di Carminiello ai Mannesi\', coords: [14.259800, 40.849500], depth: 7, desc: \"Area archeologica con impianto termale del I sec. d.C., trasformato in Mitreo nel II secolo d.C. Conserva il rilievo in stucco della \'tauroctonia\' (Mitra che uccide il toro).\" },\n  { id: 14, category: \'rifugio\', name: \'Palazzo Cellammare (Rifugio)\', coords: [14.244320, 40.835850], depth: 22, desc: \"Sotto lo storico palazzo a Chiaia si estende una vasta rete di cavit\303\240 artificiali. Durante la guerra furono riadattate come rifugio antiaereo attrezzato per i residenti del quartiere.\" },\n  { id: 15, category: \'ipogeo\', name: \'Crypta Neapolitana\', coords: [14.217550, 40.829595], depth: 45, desc: \"Imponente galleria stradale romana lunga 705 metri (37 a.C.). Collegava Mergellina con Fuorigrotta ed \303\250 legata al mito di Virgilio Mago.\" },\n  { id: 16, category: \'ipogeo\', name: \'Fossa del Grano (Via Broggia)\', coords: [14.250890, 40.852450], depth: 14, desc: \"Serie di enormi cavit\303\240 scavate nel XVII secolo per lo stoccaggio pubblico dei cereali. Successivamente incorporate nella rete acquedottistica e rifugi WWII.\" },\n  { id: 17, category: \'ipogeo\', name: \'Teatro Romano (L\\\'Anticaglia)\', coords: [14.256250, 40.851650], depth: 5, desc: \"Resti del maestoso teatro di epoca romana imperiale dove cant\303\262 l\'imperatore Nerone. Le arcate della cavea sono oggi inglobate nel tessuto urbano moderno.\" },\n  { id: 18, category: \'ipogeo\', name: \'Ipogeo dei Melograni\', coords: [14.252320, 40.857450], depth: 11, desc: \"Sito archeologico della necropoli ellenistica della Sanit\303\240. Celebre per le decorazioni dipinte dedicate al melograno, simbolo dell\'aldil\303\240.\" },\n  { id: 19, category: \'acqua\', name: \'Acquedotto del Serino (Sottosuolo)\', coords: [14.258450, 40.851210], depth: 18, desc: \"Nota come \'Aqua Augusta\', monumentale opera idraulica romana lunga 80 km. I suoi condotti attraversano il sottosuolo cittadino a quote variabili.\" },\n  { id: 20, category: \'rifugio\', name: \'Ipogeo di Piazza Plebiscito\', coords: [14.248890, 40.835850], depth: 30, desc: \"Ambienti ipogei sotto la piazza monumentale. Intersecano la Galleria Borbonica e sono stati riadattati nei secoli per la distribuzione idrica.\" },\n  { id: 21, category: \'acqua\', name: \'Cavit\303\240 Via Avvocata 25\', coords: [14.244012, 40.852521], depth: 25, desc: \"Un\'estesa porzione dell\'antico sistema acquedottistico situata nel rione Avvocata. I rilievi indicano una superficie di 2.045 mq e una volumetria di 28.630 mc.\" },\n  { id: 22, category: \'ipogeo\', name: \'Complesso Via L. Bianchi\', coords: [14.218034, 40.871054], depth: 30, desc: \"Situato alla periferia nord, questo complesso \303\250 composto da tre ampie strutture ipogee collegate. Testimonia l\'attivit\303\240 di cava intensiva.\" },\n  { id: 23, category: \'ipogeo\', name: \'Cavit\303\240 Bosco Capodimonte 17/22\', coords: [14.255087, 40.867011], depth: 18, desc: \"Vasta cava adiacente al Real Bosco. Monitorata geotecnicamente per la stabilit\303\240 del piano stradale, esempio di attivit\303\240 estrattiva privata.\" },\n  { id: 24, category: \'ipogeo\', name: \'Cavit\303\240 Via F.M. Briganti\', coords: [14.267015, 40.868032], depth: 15, desc: \"Imponente complesso caveale con superficie di 2.500 mq. Uno dei vuoti artificiali pi\303\271 vasti della zona orientale, scavato per il prelievo di materiali edili.\" },\n  { id: 25, category: \'ipogeo\', name: \'Cavit\303\240 Vico della Calce 1\', coords: [14.242043, 40.856098], depth: 25, desc: \"Situata nel Rione Stella, con volume di 25.360 mc. Caratterizzata da una fitta maglia di pilastri residui per sostenere l\'abitato soprastante.\" },\n  { id: 26, category: \'ipogeo\', name: \'Cavit\303\240 Vico Calce Materdei 30\', coords: [14.241076, 40.853045], depth: 14, desc: \"Documenta la stratificazione delle attivit\303\240 estrattive private effettuate sotto i palazzi del XVII secolo a Materdei. Volume: 5.215 mc.\" },\n  { id: 27, category: \'ipogeo\', name: \'Cavit\303\240 Salita Vecchia Capodimonte 60\', coords: [14.250032, 40.862087], depth: 12, desc: \"Cava storica situata lungo l\'antico asse di collegamento verso la collina. Caratterizzata da pareti alte circa 10 metri e un soffitto piano.\" },\n  { id: 28, category: \'acqua\', name: \'Cisterna Piazza Cavour 74\', coords: [14.252098, 40.854521], depth: 8, desc: \"Ambiente idrico di accumulo situato sotto piazza Cavour. Faceva parte del sistema di distribuzione dell\'acquedotto della Bolla.\" },\n  { id: 29, category: \'ipogeo\', name: \'Cavit\303\240 Vico Centogradi ai Cristallini 10\', coords: [14.254512, 40.858043], depth: 15, desc: \"Una delle cavit\303\240 pi\303\271 imponenti censite tecnicamente nel quartiere Stella. Occupa una superficie di 6.478 mq e una volumetria di 64.780 mc.\" },\n  { id: 30, category: \'ipogeo\', name: \'Cavit\303\240 Via Chiaia 87\', coords: [14.246543, 40.837565], depth: 15, desc: \"Vasta cavit\303\240 tecnica situata sotto l\'asse stradale di via Chiaia. Testimonia l\'attivit\303\240 estrattiva tra XVII e XVIII secolo per i palazzi della nobilt\303\240.\" },\n  { id: 31, category: \'ipogeo\', name: \'Cavit\303\240 Via Chiaia 123\', coords: [14.245587, 40.836512], depth: 10, desc: \"Ulteriore ambiente ipogeo nel quartiere San Ferdinando. Cavit\303\240 \'di prestito\' scavata per l\'edificazione del quartiere tra il XVII e il XVIII secolo.\" },\n  { id: 32, category: \'ipogeo\', name: \'Cavit\303\240 Via Chiaia 179\', coords: [14.244512, 40.835543], depth: 10, desc: \"Ambiente ipogeo nel cuore di Chiaia. Il sito \303\250 censito per fini di controllo della stabilit\303\240 e monitoraggio delle infiltrazioni idriche profonde.\" },\n  { id: 33, category: \'ipogeo\', name: \'Cavit\303\240 Salita dei Cinesi 68\', coords: [14.253076, 40.861543], depth: 8, desc: \"Ex cava di tufo situata nel quartiere Stella, attualmente riutilizzata come autorimessa privata (garage).\" },\n  { id: 34, category: \'ipogeo\', name: \'Cavit\303\240 Viale Colli Aminei 36\', coords: [14.242043, 40.872012], depth: 35, desc: \"Monumentale sistema di estrazione (oltre 206.000 mc). Una delle pi\303\271 grandi cave censite sulla collina.\" },\n  { id: 35, category: \'acqua\', name: \'Acquedotto Vico I Concezione\', coords: [14.245543, 40.844512], depth: 10, desc: \"Tratto di condotta idrica storica situata nei Quartieri Spagnoli. Documenta la densit\303\240 della rete di distribuzione ipogea seicentesca.\" },\n  { id: 36, category: \'ipogeo\', name: \'Cavit\303\240 Via Confalone 7\', coords: [14.238076, 40.851043], depth: 15, desc: \"Cava di modesta estensione situata nel quartiere Arenella. Testimonianza delle attivit\303\240 estrattive locali effettuate sui fianchi del Vomero.\" },\n  { id: 37, category: \'ipogeo\', name: \'Cavit\303\240 Via F.S. Correra 29\', coords: [14.247512, 40.850543], depth: 18, desc: \"Ampia cava nel rione Avvocata con superficie di 3.806 mq. Localizzata in area ad alta densit\303\240 abitativa.\" },\n  { id: 38, category: \'acqua\', name: \'Cisterna Via M. D\\\'Amelio 82\', coords: [14.223043, 40.858012], depth: 6, desc: \"Piccola camera idrica di accumulo situata nel quartiere Arenella. Faceva parte delle infrastrutture per l\'approvvigionamento dei casali.\" },\n  { id: 39, category: \'ipogeo\', name: \'Cava Pomici Via Forges Davanzati\', coords: [14.272512, 40.864543], depth: 4, desc: \"Nota popolarmente come \'tana di lapillo\', \303\250 un piccolo ambiente estrattivo scavato in terreni piroclastici incoerenti (pomici).\" },\n  { id: 40, category: \'ipogeo\', name: \'Cavit\303\240 Via Carlo De Marco\', coords: [14.264012, 40.866543], depth: 6, desc: \"Cava censita nel quartiere San Carlo all\'Arena. Documenta l\'attivit\303\240 estrattiva eseguita lungo le pendici esterne di Capodimonte.\" },\n  { id: 41, category: \'acqua\', name: \'Calata San Mattia 23\', coords: [14.246410, 40.838350], depth: 40, desc: \"Custodisce il pi\303\271 grande tratto intatto dell\'acquedotto del Carmignano mai rinvenuto. Il sistema comprende 30 maestose cisterne alte 40 metri.\" },\n  { id: 42, category: \'acqua\', name: \'Palazzo Serra di Cassano\', coords: [14.245800, 40.835300], depth: 30, desc: \"Sito storico che integra condotte dell\'acquedotto rinascimentale e un rifugio antiaereo WWII sulla collina di Pizzofalcone.\" },\n  { id: 43, category: \'ipogeo\', name: \'Grotta di Seiano\', coords: [14.184310, 40.798150], depth: 45, desc: \"Tunnel stradale romano lungo 770 metri scavato nel I secolo a.C. sotto la collina di Posillipo. Accesso al Parco del Pausilypon.\" },\n  { id: 44, category: \'ipogeo\', name: \'Grotta di Cocceio\', coords: [14.053600, 40.839500], depth: 30, desc: \"Galleria militare romana che collegava il lago d\'Averno con Cuma. Parte integrante delle infrastrutture logistiche del Portus Julius.\" },\n  { id: 45, category: \'ipogeo\', name: \'Grotte Platomonie (Monte Echia)\', coords: [14.247800, 40.832200], depth: 10, desc: \"Antichissime cavit\303\240 ai piedi del Monte Echia. Fornirono il tufo per l\'edificazione dei primi borghi di Chiaia e delle mura meridionali.\" },\n  { id: 46, category: \'ipogeo\', name: \'Cavit\303\240 Via Vergini 19\', coords: [14.254500, 40.856500], depth: 25, desc: \"Cava monumentale con superficie di 437 mq. Rappresenta una prova della pressione estrattiva estrema subita dal sottosuolo della Sanit\303\240.\" },\n  { id: 47, category: \'acqua\', name: \'Cavit\303\240 Via Duomo 142\', coords: [14.258800, 40.850900], depth: 15, desc: \"Cisterna monumentale dell\'acquedotto greco-romano (Bolla). Presenta tracce storiche di riadattamento per il Convento dei Gerolomini.\" },\n  { id: 48, category: \'acqua\', name: \'Cavit\303\240 Vico Carlo Carafa 14\', coords: [14.246100, 40.843800], depth: 18, desc: \"Vasto sistema ipogeo che interseca condotte dell\'acquedotto e rifugi bellici. Soggetto a monitoraggio per fragilit\303\240 strutturale.\" },\n  { id: 49, category: \'acqua\', name: \'Cavit\303\240 Vico Carcere Sanfelice 7\', coords: [14.247200, 40.845600], depth: 20, desc: \"Complesso di cisterne dell\'acquedotto greco-romano con volume di 9.520 mc. Mostra segni di degrado nei rivestimenti in muratura.\" },\n  { id: 50, category: \'acqua\', name: \'Serbatoio Amedeo di Savoia\', coords: [14.250500, 40.865200], depth: 35, desc: \"Noto come \'Serbatoio AMAN\'. Imponente bacino di accumulo idrico profondo con una volumetria colossale di 371.925 mc.\" },\n  { id: 51, category: \'rifugio\', name: \'Trinit\303\240 degli Spagnoli 31\', coords: [14.247500, 40.838900], depth: 26, desc: \"Rifugio antiaereo monumentale (50.000 mc) ricavato da un antico acquedotto, accessibile tramite una scala di 135 gradini.\" },\n  { id: 52, category: \'ipogeo\', name: \'Via S. M. Antesaecula 126\', coords: [14.252000, 40.857100], depth: 12, desc: \"Tomba a camera greca distinta dall\'Ipogeo dei Togati. Testimonianza della necropoli ellenistica extra-moenia di Neapolis.\" },\n  { id: 53, category: \'acqua\', name: \'Cavit\303\240 Via Chiaia 216\', coords: [14.245800, 40.837800], depth: 28, desc: \"Vasta cavit\303\240 tecnica collegata al sistema idrico dei Quartieri Spagnoli. Uno dei vuoti artificiali pi\303\271 ampi documentati sotto Chiaia.\" },\n  { id: 54, category: \'ipogeo\', name: \'Via Arenaccia (Gussone)\', coords: [14.266500, 40.858500], depth: 28, desc: \"Sito stratigrafico identificato tramite sondaggi geologici profondi che hanno intercettato il banco di tufo a 28 metri.\" },\n  { id: 55, category: \'ipogeo\', name: \'Piazza S. Maria della Fede\', coords: [14.268200, 40.856800], depth: 38, desc: \"Sito di eccezionale interesse stratigrafico dove il tufo giallo viene intercettato a 38 metri dal piano campagna.\" },\n  { id: 56, category: \'acqua\', name: \'Cavit\303\240 Via Nicotera (Cisterna)\', coords: [14.245500, 40.836200], depth: 20, desc: \"Ambiente ipogeo appartenente all\'acquedotto del Carmignano. Caratterizzato da cisterne a quote differenziate per l\'attingimento.\" },\n  { id: 57, category: \'ipogeo\', name: \'Complesso dello Scudillo\', coords: [14.242100, 40.865500], depth: 45, desc: \"Il sistema caveale pi\303\271 maestoso di Napoli (838.000 mc). Durante la guerra fu enorme deposito di munizioni teatrale di un\'esplosione nel 1944.\" },\n  { id: 58, category: \'rifugio\', name: \'Giardino di Babuk (Cavit\303\240)\', coords: [14.258500, 40.856100], depth: 15, desc: \"Cavit\303\240 sotto un giardino nobiliare. Utilizzata come rifugio antiaereo e oggi sede di eventi culturali e spettacoli teatrali.\" },\n  { id: 59, category: \'acqua\', name: \'Piscina Mirabilis (Bacoli)\', coords: [14.081500, 40.795000], depth: 15, desc: \"Definita la \'Cattedrale dell\'Acqua\', terminale dell\'acquedotto Augusteo. Capacit\303\240 di 12.000 mc destinata alla flotta imperiale di Miseno.\" },\n  { id: 60, category: \'ipogeo\', name: \'Tombe a Forno di Materdei\', coords: [14.242500, 40.853500], depth: 6, desc: \"I pi\303\271 antichi esempi di cavit\303\240 artificiali di Napoli (4.500 anni fa), attribuiti alla cultura del Gaudo. Sepolture a camera scavate nel tufo.\" }\n];\n\nexport const TRIPS_DATA: Trip[] = [\n  { path: [[14.265, 40.855], [14.260, 40.852], [14.256, 40.850], [14.250, 40.848]], timestamps: [0, 300, 600, 1000], color: [74, 139, 201] },\n  { path: [[14.256, 40.850], [14.254, 40.844], [14.248, 40.838], [14.243, 40.833]], timestamps: [200, 500, 800, 1000], color: [201, 168, 76] }\n];\n"
    }
