      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEWMONxO8zYVjNJxY36Ry_Ya2KiIti1uZieQdsSpKfZGdLT748X1L5yqZGUMw8z1-qjnvapPHpMLEb6s5dEgKKGPehanLgoV0ztItGNILVro6_FV0yE2hhalm-VPR8oRyRCFeEBtVxfenmsjn22kpWmaci7s_4icPsdSxVpF1HcocI-j35Jxw=="
