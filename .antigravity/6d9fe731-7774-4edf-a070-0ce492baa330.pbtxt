    instruction: "Style the SiteCard component to match the new high-class light-academic color scheme from the image"
    replacement_infos {
      original_chunk {
        target_content: "export const SiteCard: React.FC<SiteCardProps> = ({ site, isActive, onSelect }) => {\n  // Translate categories to Italian descriptive text for the visual metadata\n  const getCategoryLabelShort = (cat: string) => {\n    switch (cat) {\n      case \'acqua\':\n        return \'Acquedotto\';\n      case \'catacomba\':\n        return \'Necropoli\';\n      case \'rifugio\':\n        return \'Rifugio\';\n      case \'ipogeo\':\n      default:\n        return \'Ipogeo\';\n    }\n  };\n\n  return (\n    <div\n      id={`card-${site.id}`}\n      onClick={() => onSelect(site)}\n      className={`group site-card-transition p-6 cursor-pointer border-b border-gold/10 flex flex-col gap-2 relative overflow-hidden select-none\n        ${isActive \n          ? \'bg-gold/10 border-l-2 border-l-gold\' \n          : \'hover:bg-gold/5 border-l-2 border-l-transparent\'\n        }`}\n    >\n      {/* Category Glyph + Coordinate metadata */}\n      <div className=\"flex justify-between items-start text-[10px] uppercase tracking-widest mb-0.5\">\n        <span className={`flex items-center gap-1.5 font-bold transition-all ${isActive ? \'text-gold-light\' : \'text-gold\'}`}>\n          <CategoryIcon category={site.category} size={11} className=\"flex-shrink-0\" />\n          <span>Sito #{String(site.id).padStart(2, \'0\')} - {getCategoryLabelShort(site.category)}</span>\n        </span>\n        <span className=\"font-mono text-[10px] text-parchment/40\">\n          {site.coords[1].toFixed(2)}\302\260 N / {site.coords[0].toFixed(2)}\302\260 E\n        </span>\n      </div>\n\n      {/* Site Name and Initial Snippet */}\n      <div className=\"flex flex-col gap-1.5\">\n        <h3 className={`font-serif text-[17px] leading-snug tracking-normal transition-colors\n          ${isActive ? \'text-gold\' : \'text-parchment group-hover:text-gold\'}`}>\n          {site.name}\n        </h3>\n        <p className={`font-sans text-[12.5px] leading-relaxed line-clamp-2 transition-opacity\n          ${isActive ? \'opacity-90\' : \'opacity-50 group-hover:opacity-80\'}`}>\n          {site.desc}\n        </p>\n      </div>\n\n      {/* Depth Indicator Badge */}\n      <div className=\"flex items-center justify-between mt-2 pt-2 border-t border-gold/5\">\n        <span className=\"font-sans text-[10px] text-dust-light/40 uppercase tracking-wider font-light\">\n          Registro Geotecnico\n        </span>\n        <span className={`font-mono text-[11px] font-bold px-1.5 py-0.5 rounded-sm bg-black/40 border border-gold-dim/20\n          ${isActive ? \'text-gold-light\' : \'text-gold-dim\'}`}>\n          -{site.depth}.00 MT\n        </span>\n      </div>\n    </div>\n  );\n};"
        replacement_content: "export const SiteCard: React.FC<SiteCardProps> = ({ site, isActive, onSelect }) => {\n  // Translate categories to Italian descriptive text for the visual metadata\n  const getCategoryLabelShort = (cat: string) => {\n    switch (cat) {\n      case \'acqua\':\n        return \'Acquedotto\';\n      case \'catacomba\':\n        return \'Necropoli\';\n      case \'rifugio\':\n        return \'Rifugio\';\n      case \'ipogeo\':\n      default:\n        return \'Ipogeo\';\n    }\n  };\n\n  return (\n    <div\n      id={`card-${site.id}`}\n      onClick={() => onSelect(site)}\n      className={`group site-card-transition p-6 cursor-pointer border-b border-brand-border/30 flex flex-col gap-2 relative overflow-hidden select-none\n        ${isActive \n          ? \'bg-brand-surface border-l-4 border-l-brand-primary shadow-sm\' \n          : \'hover:bg-brand-surface/40 border-l-4 border-l-transparent\'\n        }`}\n    >\n      {/* Category Glyph + Coordinate metadata */}\n      <div className=\"flex justify-between items-start text-[10px] uppercase tracking-wider mb-0.5 font-mono\">\n        <span className={`flex items-center gap-1.5 font-bold transition-all ${isActive ? \'text-brand-accent\' : \'text-brand-primary\'}`}>\n          <CategoryIcon category={site.category} size={11} className=\"flex-shrink-0\" />\n          <span>Sito #{String(site.id).padStart(2, \'0\')} \302\267 {getCategoryLabelShort(site.category)}</span>\n        </span>\n        <span className=\"text-[10px] text-brand-text/50\">\n          {site.coords[1].toFixed(2)}\302\260 N / {site.coords[0].toFixed(2)}\302\260 E\n        </span>\n      </div>\n\n      {/* Site Name and Initial Snippet */}\n      <div className=\"flex flex-col gap-1.5\">\n        <h3 className={`font-serif text-[18px] font-bold leading-snug tracking-normal transition-colors\n          ${isActive ? \'text-brand-text\' : \'text-brand-text/85 group-hover:text-brand-primary\'}`}>\n          {site.name}\n        </h3>\n        <p className={`font-sans text-[12.5px] leading-relaxed line-clamp-2 transition-opacity\n          ${isActive ? \'text-brand-text/90\' : \'text-brand-text/60 group-hover:text-brand-text/80\'}`}>\n          {site.desc}\n        </p>\n      </div>\n\n      {/* Depth Indicator Badge */}\n      <div className=\"flex items-center justify-between mt-2 pt-2 border-t border-brand-border/25\">\n        <span className=\"font-sans text-[10px] text-brand-text/40 uppercase tracking-widest font-light\">\n          Registro Geotecnico\n        </span>\n        <span className={`font-mono text-[11px] font-bold px-1.5 py-0.5 rounded-sm bg-brand-bg border border-brand-border/40\n          ${isActive ? \'text-brand-accent\' : \'text-brand-primary\'}`}>\n          -{site.depth}.00 MT\n        </span>\n      </div>\n    </div>\n  );\n};"
