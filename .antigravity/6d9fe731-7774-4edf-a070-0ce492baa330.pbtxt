    web_documents {
      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQH3L4HycrkmbvH1mXl_ji60NY83SqII-pUUoeDyKZfzBnAZHEKOIKOMWRCU981Wr9OIKvnEjGhOmzld2ySsb7NKUpXVfVVXw3I5pvcmAGeDwOb0QoxtSIraPlC_giWll9fgK1WWwxQ4CcBJ_qg="
