      replacement_content: "@import \"tailwindcss\";\n\n@theme {\n  --color-gold: #C9A84C;\n  --color-gold-light: #E8C97A;\n  --color-gold-dim: #8B6E2E;\n  --color-ink: #0A0806;\n  --color-parchment: #F5EDD8;\n  --color-stone: #2A2520;\n  --color-stone-light: #3D3630;\n  --color-dust: #6B5E4E;\n  --color-dust-light: #9E8E7A;\n  --color-glow-amber: rgba(201, 168, 76, 0.15);\n\n  --font-serif: \'Playfair Display\', Georgia, Cambria, \"Times New Roman\", Times, serif;\n  --font-sans: \'Inter\', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif;\n}\n\nbody, html {\n  margin: 0;\n  padding: 0;\n  width: 100%;\n  height: 100%;\n  background-color: #0A0806; /* Ink */\n  color: #F5EDD8; /* Parchment */\n  font-family: \'Inter\', sans-serif;\n  overflow: hidden;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}\n\n/* Base custom scrollbar styling */\n::-webkit-scrollbar {\n  width: 5px;\n  height: 5px;\n}\n\n::-webkit-scrollbar-track {\n  background: #0A0806;\n}\n\n::-webkit-scrollbar-thumb {\n  background: #8B6E2E;\n  border-radius: 2px;\n}\n\n::-webkit-scrollbar-thumb:hover {\n  background: #C9A84C;\n}\n\n/* Custom transitions and interactive feedback classes */\n.site-card-transition {\n  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);\n}\n\n.glow-classic-border {\n  border-color: rgba(201, 168, 76, 0.3);\n  box-shadow: 0 0 15px rgba(201,168,76,0.05);\n}\n\n.glow-classic-border:hover {\n  border-color: rgba(201, 168, 76, 0.6);\n  box-shadow: 0 0 25px rgba(201,168,76,0.12);\n}\n\n/* Deck.gl overlay configuration */\n.deck-tooltip {\n  background: #0A0806 !important;\n  border: 1px solid #C9A84C !important;\n  color: #F5EDD8 !important;\n  font-family: \'Playfair Display\', serif !important;\n  padding: 14px 18px !important;\n  border-radius: 0px !important;\n  font-size: 14px !important;\n  box-shadow: 0 10px 30px rgba(0,0,0,0.95) !important;\n  line-height: 1.5 !important;\n  max-width: 320px !important;\n  pointer-events: none !important;\n  text-align: left !important;\n  z-index: 999999 !important;\n}\n\n/* Custom styled badge helper */\n.badge-archaeology {\n  font-family: \'Inter\', sans-serif;\n  font-size: 9px;\n  letter-spacing: 0.15em;\n  text-transform: uppercase;\n  font-weight: 700;\n  padding: 3px 8px;\n  border-radius: 1px;\n  border: 1px solid currentColor;\n}\n"
