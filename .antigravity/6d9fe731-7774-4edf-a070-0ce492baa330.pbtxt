        target_content: "@import \"tailwindcss\";\n\n@theme {\n  --color-gold: #C9A84C;\n  --color-gold-light: #E8C97A;\n  --color-gold-dim: #8B6E2E;\n  --color-ink: #0A0806;\n  --color-parchment: #F5EDD8;\n  --color-stone: #2A2520;\n  --color-stone-light: #3D3630;\n  --color-dust: #6B5E4E;\n  --color-dust-light: #9E8E7A;\n  --color-glow-amber: rgba(201, 168, 76, 0.15);\n\n  --font-serif: \'Playfair Display\', Georgia, Cambria, \"Times New Roman\", Times, serif;\n  --font-sans: \'Inter\', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif;\n}\n\nbody, html {\n  margin: 0;\n  padding: 0;\n  width: 100%;\n  height: 100%;\n  background-color: #0A0806; /* Ink */\n  color: #F5EDD8; /* Parchment */\n  font-family: \'Inter\', sans-serif;\n  overflow: hidden;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}"
        replacement_content: "@import \"tailwindcss\";\n\n@theme {\n  --color-brand-bg: #FFEDDD;\n  --color-brand-text: #3A0000;\n  --color-brand-primary: #92400E;\n  --color-brand-accent: #771700;\n  --color-brand-surface: #FFFFFF;\n  --color-brand-border: #FFB580;\n\n  /* Legacy variable mappings to maintain component compatibility seamlessly */\n  --color-gold: #92400E;\n  --color-gold-light: #FFB580;\n  --color-gold-dim: #771700;\n  --color-ink: #FFEDDD;\n  --color-parchment: #3A0000;\n  --color-stone: #FFB580;\n  --color-stone-light: #FFFFFF;\n  --color-dust: #92400E;\n  --color-dust-light: #771700;\n  --color-glow-amber: rgba(146, 64, 14, 0.08);\n\n  --font-serif: \'EB Garamond\', \'Playfair Display\', Georgia, serif;\n  --font-mono: \'DM Mono\', monospace;\n  --font-sans: \'Inter\', ui-sans-serif, sans-serif;\n}\n\nbody, html {\n  margin: 0;\n  padding: 0;\n  width: 100%;\n  height: 100%;\n  background-color: #FFEDDD; /* brand-bg */\n  color: #3A0000; /* brand-text */\n  font-family: \'Inter\', sans-serif;\n  overflow: hidden;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}"
