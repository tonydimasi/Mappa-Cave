    instruction: "Upgrade card styling to match the Sophisticated Dark theme specifications"
    replacement_infos {
      original_chunk {
        target_content: "export const SiteCard: React.FC<SiteCardProps> = ({ site, isActive, onSelect }) => {\n  // Translate categories to Italian descriptive text for the visual metadata\n  const getCategoryLabel = (cat: string) => {\n    switch (cat) {\n      case \'acqua\':\n        return \'Acquedotto / Cisterna\';\n      case \'catacomba\':\n        return \'Necropoli / Cripta\';\n      case \'rifugio\':\n        return \'Rifugio Antiaereo\';\n      case \'ipogeo\':\n      default:\n        return \'Ipogeo Ellenistico\';\n    }\n  };\n\n  // Fetch color style class for category types\n  const getCategoryColorClass = (cat: string) => {\n    switch (cat) {\n      case \'acqua\':\n        return \'text-sky-400 border-sky-400/20 bg-sky-950/20\';\n      case \'catacomba\':\n        return \'text-red-400 border-red-400/20 bg-red-950/20\';\n      case \'rifugio\':\n        return \'text-emerald-400 border-emerald-400/20 bg-emerald-950/20\';\n      case \'ipogeo\':\n      default:\n        return \'text-gold-light border-gold-dim/30 bg-gold-dim/10\';\n    }\n  };\n\n  return (\n    <div\n      id={`card-${site.id}`}\n      onClick={() => onSelect(site)}\n      className={`site-card-transition p-5 cursor-pointer border-b border-stone-light/10 flex flex-col gap-3.5 relative overflow-hidden select-none\n        ${isActive \n          ? \'bg-glow-amber/20 border-l-4 border-l-gold pl-4.5\' \n          : \'hover:bg-glow-amber/5 border-l-4 border-l-transparent\'\n        }`}\n    >\n      {/* Category Glyph + Text badge */}\n      <div className=\"flex items-center justify-between\">\n        <span className={`badge-archaeology flex items-center gap-1.5 ${getCategoryColorClass(site.category)}`}>\n          <CategoryIcon category={site.category} size={11} className=\"flex-shrink-0\" />\n          <span>{getCategoryLabel(site.category)}</span>\n        </span>\n        <span className=\"font-mono text-[10px] text-gold-dim/80 uppercase tracking-widest\">\n          Prof. {site.depth}M\n        </span>\n      </div>\n\n      {/* Site Name and Initial Snippet */}\n      <div className=\"flex flex-col gap-1.5\">\n        <h3 className=\"font-serif text-[15px] font-semibold text-parchment leading-snug tracking-normal\">\n          {site.name}\n        </h3>\n        <p className=\"font-sans text-[12px] text-dust-light/80 font-light line-clamp-2 leading-relaxed\">\n          {site.desc}\n        </p>\n      </div>\n\n      {/* Muted coordinates for historical records */}\n      <div className=\"flex items-center gap-2 font-mono text-[9px] text-dust/60\">\n        <span>GPS:</span>\n        <span>{site.coords[1].toFixed(5)}\302\260N, {site.coords[0].toFixed(5)}\302\260E</span>\n      </div>\n    </div>\n  );\n};"
        replacement_content: "export const SiteCard: React.FC<SiteCardProps> = ({ site, isActive, onSelect }) => {\n  // Translate categories to Italian descriptive text for the visual metadata\n  const getCategoryLabelShort = (cat: string) => {\n    switch (cat) {\n      case \'acqua\':\n        return \'Acquedotto\';\n      case \'catacomba\':\n        return \'Necropoli\';\n      case \'rifugio\':\n        return \'Rifugio\';\n      case \'ipogeo\':\n      default:\n        return \'Ipogeo\';\n    }\n  };\n\n  return (\n    <div\n      id={`card-${site.id}`}\n      onClick={() => onSelect(site)}\n      className={`group site-card-transition p-6 cursor-pointer border-b border-gold/10 flex flex-col gap-2 relative overflow-hidden select-none\n        ${isActive \n          ? \'bg-gold/10 border-l-2 border-l-gold\' \n          : \'hover:bg-gold/5 border-l-2 border-l-transparent\'\n        }`}\n    >\n      {/* Category Glyph + Coordinate metadata */}\n      <div className=\"flex justify-between items-start text-[10px] uppercase tracking-widest mb-0.5\">\n        <span className={`flex items-center gap-1.5 font-bold transition-all ${isActive ? \'text-gold-light\' : \'text-gold\'}`}>\n          <CategoryIcon category={site.category} size={11} className=\"flex-shrink-0\" />\n          <span>Sito #{String(site.id).padStart(2, \'0\')} - {getCategoryLabelShort(site.category)}</span>\n        </span>\n        <span className=\"font-mono text-[10px] text-parchment/40\">\n          {site.coords[1].toFixed(2)}\302\260 N / {site.coords[0].toFixed(2)}\302\260 E\n        </span>\n      </div>\n\n      {/* Site Name and Initial Snippet */}\n      <div className=\"flex flex-col gap-1.5\">\n        <h3 className={`font-serif text-[17px] leading-snug tracking-normal transition-colors\n          ${isActive ? \'text-gold\' : \'text-parchment group-hover:text-gold\'}`}>\n          {site.name}\n        </h3>\n        <p className={`font-sans text-[12.5px] leading-relaxed line-clamp-2 transition-opacity\n          ${isActive ? \'opacity-90\' : \'opacity-50 group-hover:opacity-80\'}`}>\n          {site.desc}\n        </p>\n      </div>\n\n      {/* Depth Indicator Badge */}\n      <div className=\"flex items-center justify-between mt-2 pt-2 border-t border-gold/5\">\n        <span className=\"font-sans text-[10px] text-dust-light/40 uppercase tracking-wider font-light\">\n          Registro Geotecnico\n        </span>\n        <span className={`font-mono text-[11px] font-bold px-1.5 py-0.5 rounded-sm bg-black/40 border border-gold-dim/20\n          ${isActive ? \'text-gold-light\' : \'text-gold-dim\'}`}>\n          -{site.depth}.00 MT\n        </span>\n      </div>\n    </div>\n  );\n};"
      }
