    web_documents {
      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQFDJldpPNniXrxynUh8w7cu-Q-9U3V3b2biX6MEL_EmyRYehhgkE-RXU7bMrhrwakTIEF6C7L19W9-TDxrKQRvyGlrAAYIyReVsw73Z52sQMsvn9o8DfrJUj3LQfjKt1JmpVi4784pXULtmENWnYlfaML4R91pYb2lT7btb0nFhPjjlwLexTMMhqk7JIQ=="
      title: "github.com"
