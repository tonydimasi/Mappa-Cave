    instruction: "Refactor layout and stlying to comply with the Sophisticated Dark design theme, placing detail panel on bottom-right with parchment styling"
    replacement_infos {
      original_chunk {
        target_content: "  return (\n    <div className=\"flex w-screen h-screen relative bg-ink text-parchment font-sans overflow-hidden\">\n      {/* SIDEBAR (Fixed 420px width as requested) */}\n      <aside \n        id=\"ns-sidebar\" \n        className=\"w-[420px] h-full bg-ink border-r border-gold-dim/40 flex flex-col z-10 shadow-[20px_0_40px_rgba(0,0,0,0.95)] flex-shrink-0 relative\"\n      >\n        {/* SIDEBAR HEADER */}\n        <header id=\"ns-header\" className=\"pt-8 px-7 pb-4 border-b border-stone/60 select-none\">\n          <div className=\"flex items-center justify-between mb-1\">\n            <h1 id=\"ns-title\" className=\"font-serif text-2xl font-bold tracking-tight text-gold\">\n              Napoli Sotterranea\n            </h1>\n            <span className=\"font-mono text-[9px] text-gold/60 border border-gold-dim/30 px-1.5 py-0.5 rounded-sm\">\n              BETA 1\n            </span>\n          </div>\n          <div id=\"ns-subtitle\" className=\"text-[10px] text-dust-light font-semibold tracking-[0.16em] uppercase\">\n            Sistema Geospaziale Unicum \302\267 Archivio\n          </div>\n        </header>\n\n        {/* INTEGRATED HISTORICAL SEARCH BAR */}\n        <div className=\"px-7 py-3 border-b border-stone/40 bg-black/20\">\n          <div className=\"relative flex items-center\">\n            <span className=\"absolute left-3.5 text-gold-dim/70\">\n              <Search size={14} />\n            </span>\n            <input\n              type=\"text\"\n              value={searchQuery}\n              onChange={(e) => setSearchQuery(e.target.value)}\n              placeholder=\"Cerca per nome o descrizione sacra...\"\n              className=\"w-full bg-stone-light/10 border border-gold-dim/30 hover:border-gold-dim/50 focus:border-gold focus:ring-1 focus:ring-gold/30 text-[12.5px] placeholder-dust-light/40 py-2.5 pl-9 pr-8 text-parchment outline-none transition-all rounded-none font-sans\"\n            />\n            {searchQuery && (\n              <button\n                onClick={() => setSearchQuery(\'\')}\n                className=\"absolute right-3 text-dust hover:text-gold-light transition-colors\"\n                title=\"Cancella ricerca\"\n              >\n                <X size={14} />\n              </button>\n            )}\n          </div>\n        </div>\n\n        {/* TABS FILTRO (All categories with inline illustrated glyph icons) */}\n        <nav id=\"ns-tabs\" className=\"grid grid-cols-5 gap-1.5 p-3 px-5 bg-black/45 border-b border-stone/50 select-none\">\n          {([\'all\', \'acqua\', \'catacomba\', \'rifugio\', \'ipogeo\'] as const).map((cat) => (\n            <button\n              key={cat}\n              onClick={() => {\n                setCategoryFilter(cat);\n                setSelectedSite(null); // Clear active selected to trigger pristine intro\n              }}\n              className={`flex flex-col items-center justify-center py-2.5 px-0.5 border transition-all cursor-pointer rounded-none gap-1\n                ${categoryFilter === cat\n                  ? \'border-gold text-gold bg-glow-amber/15 shadow-[inset_0_0_10px_rgba(201,168,76,0.1)] font-medium\'\n                  : \'border-dust/30 text-dust-light/70 hover:border-dust/70 hover:text-parchment\'\n                }`}\n            >\n              {cat !== \'all\' ? (\n                <CategoryIcon category={cat} size={15} className=\"opacity-90\" />\n              ) : (\n                <Layers size={13} className=\"opacity-90\" />\n              )}\n              <span className=\"text-[9px] tracking-wide uppercase font-bold text-center\">\n                {getCategoryTitle(cat)}\n              </span>\n            </button>\n          ))}\n        </nav>\n\n        {/* STATIC LEDGER STATS INDICATORS */}\n        <div className=\"px-7 py-2 bg-stone-light/10 border-b border-stone/30 flex items-center justify-between text-[11px] text-dust-light select-none\">\n          <div className=\"flex items-center gap-1.5\">\n            <Compass size={11} className=\"text-gold-dim\" />\n            <span>Siti: <strong className=\"text-gold font-mono\">{stats.count}</strong></span>\n          </div>\n          <div className=\"flex items-center gap-1.5\">\n            <TrendingDown size={11} className=\"text-gold-dim\" />\n            <span>Profondit\303\240 Media: <strong className=\"text-gold font-mono\">{stats.avgDepth}m</strong></span>\n          </div>\n          <div className=\"flex items-center gap-1.5 font-mono text-[10px] text-gold-dim\">\n            <span>Max: {stats.maxDepth}m</span>\n          </div>\n        </div>\n\n        {/* SCROLLABLE SITE LIST */}\n        <section \n          id=\"ns-list\" \n          className=\"flex-1 overflow-y-auto bg-[#0a0806]/40 dividing-y dividing-stone-light/5\"\n        >\n          {filteredSites.length > 0 ? (\n            filteredSites.map((site) => (\n              <SiteCard\n                key={site.id}\n                site={site}\n                isActive={selectedSite !== null && selectedSite.id === site.id}\n                onSelect={handleSelectSite}\n              />\n            ))\n          ) : (\n            <div className=\"p-10 text-center select-none\">\n              <BookOpen className=\"mx-auto w-10 h-10 stroke-[1.2] text-dust mb-3 opacity-60\" />\n              <p className=\"font-serif text-[15px] text-gold-dim mb-1 font-semibold\">\n                Nessun reperto trovato\n              </p>\n              <p className=\"font-sans text-[12px] text-dust-light/60 font-light max-w-[240px] mx-auto leading-relaxed\">\n                Nessuna cavit\303\240 sotterranea corrisponde al termine ricercato.\n              </p>\n            </div>\n          )}\n        </section>\n\n        {/* HISTORICAL DETAILED PANEL (Fitted height 320px as requested) */}\n        <footer \n          id=\"ns-detail\" \n          className={`h-[330px] border-t border-gold-dim/40 bg-[#0f0c0a] flex flex-col relative overflow-hidden select-none site-card-transition\n            ${selectedSite ? \'opacity-100 flex\' : \'opacity-100 flex\'}`}\n        >\n          {selectedSite ? (\n            <div className=\"h-full flex flex-col p-6.5 justify-between\">\n              {/* Heading */}\n              <div className=\"flex flex-col gap-1 overflow-y-auto\">\n                <div className=\"flex items-start justify-between gap-4\">\n                  <span className=\"font-serif italic text-[11px] text-gold uppercase tracking-[0.2em]\">\n                    Sito Unicum #{selectedSite.id} \302\267 Cat. {selectedSite.category.toUpperCase()}\n                  </span>\n                  \n                  {/* Category Glyphs badge indicator */}\n                  <div className=\"w-8 h-8 rounded-none border border-gold-dim/30 bg-black/40 flex items-center justify-center text-gold flex-shrink-0 shadow-sm\">\n                    <CategoryIcon category={selectedSite.category} size={18} />\n                  </div>\n                </div>\n\n                <h2 id=\"det-name\" className=\"font-serif text-[18px] font-bold text-gold tracking-tight leading-snug mt-1 border-b border-stone/50 pb-2\">\n                  {selectedSite.name}\n                </h2>\n\n                <p id=\"det-desc\" className=\"font-sans text-[12.5px] leading-[1.8] text-dust-light font-light text-justify pr-1.5 mt-2 overflow-y-auto max-h-[145px]\">\n                  {selectedSite.desc}\n                </p>\n              </div>\n\n              {/* Dynamic Tactile Depth Gauge */}\n              <div className=\"border-t border-stone-light/30 pt-3 flex items-center justify-between select-none bg-stone-light/5 -mx-6.5 -mb-6.5 px-6.5 pb-4 mt-3\">\n                <div className=\"flex items-center gap-3\">\n                  {/* Gauge vertical bar */}\n                  <div className=\"w-32 h-2.5 bg-ink border border-gold-dim/30 relative overflow-hidden\">\n                    {/* Fill bar showing depth mapped to 0-50 meters */}\n                    <div \n                      className=\"absolute left-0 top-0 h-full bg-gradient-to-r from-gold-dim via-gold to-gold-light transition-all duration-700 ease-out\"\n                      style={{ width: `${Math.min(100, (selectedSite.depth / 50) * 100)}%` }}\n                    />\n                  </div>\n                  <span className=\"font-mono text-[10px] text-gold-dim\">\n                    0m <span className=\"mx-0.5\">\342\200\223</span> 50m max\n                  </span>\n                </div>\n\n                <div className=\"flex flex-col items-end\">\n                  <span className=\"text-[9px] uppercase tracking-widest text-dust-light font-medium\">\n                    Profondit\303\240 Rilevata\n                  </span>\n                  <span className=\"font-serif text-[18px] font-bold text-parchment leading-none mt-0.5\">\n                    {selectedSite.depth} <span className=\"text-gold font-sans font-normal text-[11px]\">metri</span>\n                  </span>\n                </div>\n              </div>\n            </div>\n          ) : (\n            /* Antique Ledger Placeholder introduction when nothing chosen */\n            <div className=\"h-full p-8 flex flex-col justify-center items-center text-center gap-4\">\n              <div className=\"w-11 h-11 rounded-full border border-gold-dim/40 flex items-center justify-center text-gold-dim/80 bg-black/20 mb-1\">\n                <Compass size={20} className=\"animate-spin\" style={{ animationDuration: \'40s\' }} />\n              </div>\n              <h4 className=\"font-serif text-gold text-[15px] font-semibold tracking-wide\">\n                Catalogo Geospaziale Unicum\n              </h4>\n              <p className=\"font-sans text-[12px] leading-[1.7] text-dust-light max-w-[280px] font-light\">\n                Per favore, seleziona una delle <strong className=\"text-gold\">60 cavit\303\240</strong> nel catalogo della sidebar o sulla mappa geospaziale per iniziare la decrittazione storica, misurare i metri di quota e attivare il volo cinematico.\n              </p>\n              <span className=\"font-serif italic text-[10px] text-gold-dim/50 border-t border-stone-light/30 w-36 pt-2.5 mt-1 select-none\">\n                Curia Archeologia Napoli\n              </span>\n            </div>\n          )}\n        </footer>\n      </aside>\n\n      {/* DECK.GL MAP DISPLAY WRAPPER (Flexible balance of layout) */}\n      <main id=\"map-wrapper\" className=\"flex-1 h-full relative\">\n        <UndergroundMap\n          selectedSite={selectedSite}\n          categoryFilter={categoryFilter}\n          searchQuery={searchQuery}\n          onSelectSite={handleSelectSite}\n        />\n      </main>\n    </div>\n  );"
        replacement_content: "  return (\n    <div className=\"flex w-screen h-screen relative bg-ink text-parchment font-sans overflow-hidden\">\n      {/* SIDEBAR (Fixed 420px width aligned with Design HTML) */}\n      <aside \n        id=\"ns-sidebar\" \n        className=\"w-[420px] h-full bg-ink border-r border-[#C9A84C]/40 flex flex-col z-20 text-[#F5EDD8] relative flex-shrink-0\"\n      >\n        {/* SIDEBAR HEADER */}\n        <header id=\"ns-header\" className=\"p-8 border-b border-[#C9A84C]/20 select-none\">\n          <div className=\"text-gold text-[10px] tracking-[0.3em] uppercase mb-2 font-sans font-bold\">\n            Progetto: Beta 1\n          </div>\n          <h1 id=\"ns-title\" className=\"text-4xl font-serif leading-tight\">\n            Sistema Geospaziale <span className=\"italic text-gold\">Unicum</span>\n          </h1>\n          <p className=\"mt-4 text-xs opacity-60 font-sans leading-relaxed\">\n            Catalogazione scientifica e mappatura dei complessi ipogei di Napoli. Esplorazione stratigrafica dell\'acquedotto e delle necropoli.\n          </p>\n        </header>\n\n        {/* INPUTS / TABS CONTROL CORNER (Styled like the template box #12100E) */}\n        <section className=\"px-8 py-6 bg-[#12100E] border-b border-gold/10\">\n          \n          {/* Tabs Filter Grid */}\n          <nav id=\"ns-tabs\" className=\"grid grid-cols-5 gap-1.5 mb-6 select-none\">\n            {([\'all\', \'acqua\', \'catacomba\', \'rifugio\', \'ipogeo\'] as const).map((cat) => (\n              <button\n                key={cat}\n                onClick={() => {\n                  setCategoryFilter(cat);\n                  setSelectedSite(null); // Clear selected for a pristine detail intro state\n                }}\n                className={`py-2 text-[9px] uppercase tracking-widest border transition-all cursor-pointer font-bold text-center flex flex-col items-center justify-center gap-1\n                  ${categoryFilter === cat\n                    ? \'border-gold bg-[#C9A84C] text-[#0A0806]\'\n                    : \'border-gold/30 text-gold hover:bg-[#C9A84C]/10\'\n                  }`}\n              >\n                <span className=\"text-[10px]\">\n                  {cat !== \'all\' ? (\n                    <CategoryIcon category={cat} size={11} />\n                  ) : (\n                    <Layers size={10} />\n                  )}\n                </span>\n                <span>{getCategoryTitle(cat)}</span>\n              </button>\n            ))}\n          </nav>\n\n          {/* Styled search input bottom line */}\n          <div className=\"relative\">\n            <input\n              type=\"text\"\n              value={searchQuery}\n              onChange={(e) => setSearchQuery(e.target.value)}\n              placeholder=\"Cerca sito archeologico...\"\n              className=\"w-full bg-transparent border-b border-[#C9A84C]/40 py-2.5 pr-8 text-sm focus:outline-none focus:border-[#C9A84C] placeholder:text-[#F5EDD8]/30 text-parchment outline-none font-sans\"\n            />\n            <div className=\"absolute right-0 top-3 opacity-40 text-gold\">\n              {searchQuery ? (\n                <button \n                  onClick={() => setSearchQuery(\'\')}\n                  className=\"hover:text-gold-light transition-colors\"\n                >\n                  <X size={14} />\n                </button>\n              ) : (\n                <Search size={14} />\n              )}\n            </div>\n          </div>\n        </section>\n\n        {/* STATIC GEOTECHNICAL LEDGER RATIOS */}\n        <div className=\"px-8 py-2.5 bg-black/40 border-b border-gold/10 flex items-center justify-between text-[11px] text-dust-light select-none font-sans\">\n          <div className=\"flex items-center gap-1.5\">\n            <Compass size={11} className=\"text-gold\" />\n            <span>Siti: <strong className=\"text-gold font-mono font-bold\">{stats.count}</strong></span>\n          </div>\n          <div className=\"flex items-center gap-1.5\">\n            <TrendingDown size={11} className=\"text-gold\" />\n            <span>Quanti: <strong className=\"text-gold font-mono font-bold\">-{stats.avgDepth}m</strong></span>\n          </div>\n          <div className=\"font-mono text-[9px] text-gold/60\">\n            N. Sotterraneo Beta 1\n          </div>\n        </div>\n\n        {/* SCROLLABLE SITES GRID LIST */}\n        <section \n          id=\"ns-list\" \n          className=\"flex-1 overflow-y-auto custom-scroll\"\n        >\n          {filteredSites.length > 0 ? (\n            filteredSites.map((site) => (\n              <SiteCard\n                key={site.id}\n                site={site}\n                isActive={selectedSite !== null && selectedSite.id === site.id}\n                onSelect={handleSelectSite}\n              />\n            ))\n          ) : (\n            <div className=\"p-10 text-center select-none\">\n              <BookOpen className=\"mx-auto w-10 h-10 stroke-[1.2] text-gold/45 mb-3 animate-pulse\" />\n              <p className=\"font-serif text-lg text-gold mb-1 font-semibold\">\n                Nessuna Cavit\303\240 Trovata\n              </p>\n              <p className=\"font-sans text-[12px] opacity-50 max-w-[240px] mx-auto leading-relaxed\">\n                Nessun fascicolo o reperto corrisponde ai parametri inseriti.\n              </p>\n            </div>\n          )}\n        </section>\n\n        {/* FIXED FOOTER REGISTRY BRANDING */}\n        <div className=\"p-4 bg-[#050403] text-[9.5px] text-center uppercase tracking-widest text-gold/40 border-t border-gold/10 font-mono select-none\">\n          Napoli Sotterranea \302\251 2026 - Registro Archeologico Digitale\n        </div>\n      </aside>\n\n      {/* COMPACT COMBINATION OF MAP & HIGH-CONTRAST PARCHMENT FOOTER DETAIL (Arranged for elite aesthetics) */}\n      <main className=\"flex-1 h-full flex flex-col relative bg-[#F5EDD8]\">\n        \n        {/* MAP DISPLAY FRAME (Restricting viewable height dynamically with CSS flex) */}\n        <section id=\"map-height-wrapper\" className=\"flex-1 relative overflow-hidden bg-black\">\n          <UndergroundMap\n            selectedSite={selectedSite}\n            categoryFilter={categoryFilter}\n            searchQuery={searchQuery}\n            onSelectSite={handleSelectSite}\n          />\n        </section>\n\n        {/* DETAILED HIGH-CONTRAST PARCHMENT REGISTER (Parchment bg, dark ink txt) */}\n        <footer \n          id=\"ns-detail\" \n          className=\"h-[250px] bg-[#F5EDD8] border-t-2 border-[#0A0806] flex relative z-10 text-[#0A0806] select-none\"\n        >\n          {/* LEFT CONTAINER (40% width, metadata summaries & simulated interactive utilities) */}\n          <div className=\"w-[40%] p-8 border-r border-[#0A0806]/10 flex flex-col justify-between h-full\">\n            <div>\n              <div className=\"flex items-center gap-3 mb-2.5 flex-wrap\">\n                <h2 id=\"det-name\" className=\"text-2xl font-serif font-bold text-[#0A0806] leading-tight truncate max-w-[240px]\" title={selectedSite ? selectedSite.name : \'Unicum\'}>\n                  {selectedSite ? selectedSite.name.split(\' (\')[0] : \'Sito non selezionato\'}\n                </h2>\n                <span className=\"px-2 py-0.5 bg-[#0A0806] text-[#C9A84C] text-[10px] uppercase font-mono font-bold tracking-wider mt-0.5\">\n                  {selectedSite ? getCategoryTitle(selectedSite.category) : \'Generale\'}\n                </span>\n              </div>\n\n              {/* Archeological Metrics indicators */}\n              <div className=\"flex gap-5 mt-4\">\n                <div className=\"flex flex-col\">\n                  <span className=\"text-[9px] uppercase opacity-50 font-bold tracking-wider\">Profondit\303\240</span>\n                  <span className=\"text-sm font-sans font-bold text-[#0A0806]\">\n                    {selectedSite ? `-${selectedSite.depth}.00` : \'\342\200\223\342\200\223\'} MT\n                  </span>\n                </div>\n                <div className=\"flex flex-col\">\n                  <span className=\"text-[9px] uppercase opacity-50 font-bold tracking-wider\">Umidit\303\240</span>\n                  <span className=\"text-sm font-sans font-bold text-[#0A0806]\">\n                    {selectedSite ? (selectedSite.depth > 20 ? \'88%\' : \'74%\') : \'\342\200\223\342\200\223\'}\n                  </span>\n                </div>\n                <div className=\"flex flex-col\">\n                  <span className=\"text-[9px] uppercase opacity-50 font-bold tracking-wider\">Stato</span>\n                  <span className=\"text-sm font-sans font-bold text-[#C9A84C] tracking-wide\">\n                    {selectedSite ? \'ISPEZIONABILE\' : \'STABILE\'}\n                  </span>\n                </div>\n              </div>\n            </div>\n\n            {/* Click actionable tactile layout trigger button */}\n            <button \n              onClick={() => {\n                if (selectedSite) {\n                  // Prompt showing real historical catalog coordinates\n                  alert(`Dispositivo di scansione 3D pronto sul sito:\\n${selectedSite.name}\\nCoordinate: ${selectedSite.coords[1]}\302\260 N, ${selectedSite.coords[0]}\302\260 E`);\n                } else {\n                  alert(\"Seleziona una cavit\303\240 sotterranea nel menu per inizializzare il modello tridimensionale.\");\n                }\n              }}\n              className=\"border border-[#0A0806] px-5 py-2 text-xs uppercase tracking-widest font-bold hover:bg-[#0A0806] hover:text-[#F5EDD8] cursor-pointer transition-all self-start\"\n            >\n              Visualizza Rilievo 3D\n            </button>\n          </div>\n          \n          {/* RIGHT CONTAINER (Dossier narrative with luxury serif alignment) */}\n          <div className=\"flex-1 p-8 overflow-y-auto custom-scroll bg-gradient-to-r from-transparent to-[#C9A84C]/5 flex flex-col\">\n            <h4 className=\"text-[10px] uppercase tracking-widest opacity-40 mb-3 font-mono font-bold\">\n              Dossier Tecnico / Archivio Storico\n            </h4>\n            <p id=\"det-desc\" className=\"text-[13.5px] leading-relaxed text-[#0A0806]/80 font-serif text-justify overflow-y-auto pr-1\">\n              {selectedSite \n                ? selectedSite.desc \n                : \"Il Sistema Geospaziale Unicum costituisce la mappatura ufficiale delle cavit\303\240 ipogee e dei condotti idrici storici della citt\303\240 di Napoli. Esplora il catalogo di 60 complessi archeologici mediante i filtri tipologici o seleziona un punto sulla mappa orbitale tridimensionale per consultare la sismologia, la stratigrafia e i metri esatti di profondit\303\240 dal piano stradale.\"}\n            </p>\n          </div>\n        </footer>\n      </main>\n    </div>\n  );"
      }
      num_matches: 1
    }
  }
}
